using System;
using System.Collections;
using System.Collections.Generic;
using BepInEx.Logging;
using HarmonyLib;
using Photon.Pun;
using UnityEngine;
using UnityEngine.SceneManagement;
using Zorro.Core;
using PhotonHashtable =
    ExitGames.Client.Photon.Hashtable;

namespace Sapphire009.WatchEgg
{
    /// <summary>
    /// Airport를 제외한 첫 번째 게임 맵에서
    /// 모든 접속 플레이어의 캐릭터 생성이 완료되면,
    /// 호스트가 플레이어 한 명을 무작위로 선택합니다.
    ///
    /// 선택된 플레이어에게 NestEgg 하나를 지급한 뒤
    /// 해당 슬롯을 즉시 장착하여 달걀을 손에 들게 합니다.
    ///
    /// 4명 접속 시 4명 중 무작위 1명,
    /// 3명 접속 시 3명 중 무작위 1명,
    /// 2명 접속 시 2명 중 무작위 1명에게만 지급됩니다.
    ///
    /// Developer: Sapphire009
    /// File: RandomStartEgg.cs
    /// </summary>
    [HarmonyPatch(
        typeof(CharacterSpawner),
        "Update")]
    public static class RandomStartEgg
    {
        public const string DeveloperName =
            "Sapphire009";

        public const string TargetPrefabName =
            "NestEgg";

        /// <summary>
        /// 모든 플레이어의 캐릭터가 발견된 뒤
        /// 접속 인원이 안정적으로 유지되어야 하는 시간입니다.
        /// </summary>
        private const float RequiredStableTime =
            1.5f;

        /// <summary>
        /// 장착 요청이 정상 처리되지 않았을 때
        /// 다시 요청하기까지 기다리는 시간입니다.
        /// </summary>
        private const float EquipRetryInterval =
            2f;

        private const string LogPrefix =
            "[RandomStartEgg] ";

        /// <summary>
        /// 시작 달걀이 이미 지급되었는지 저장합니다.
        /// </summary>
        private const string RoomPropertyGrantedKey =
            "Sapphire009.WatchEgg.StartEggGranted";

        /// <summary>
        /// 달걀을 받을 플레이어의 Photon ActorNumber입니다.
        /// </summary>
        private const string RoomPropertyActorKey =
            "Sapphire009.WatchEgg.StartEggActor";

        /// <summary>
        /// NestEgg가 추가된 인벤토리 슬롯 번호입니다.
        ///
        /// PEAK의 아이템 장착 시스템은 인벤토리 슬롯을 기반으로
        /// 실제 아이템을 생성하고 손에 장착하므로,
        /// 선택된 플레이어의 클라이언트가 이 슬롯을 즉시 장착합니다.
        /// </summary>
        private const string RoomPropertySlotKey =
            "Sapphire009.WatchEgg.StartEggSlot";

        private static readonly ManualLogSource Logger =
            BepInEx.Logging.Logger.CreateLogSource(
                "WatchEgg.RandomStartEgg");

        private static int currentSceneHandle =
            int.MinValue;

        private static bool routineStarted;

        private static bool eggGranted;

        private static bool airportPropertyReset;

        private static bool localEquipRoutineStarted;

        private static bool localEquipCompleted;

        private static int lastLoggedReadyCount =
            -1;

        [HarmonyPrepare]
        private static bool Prepare()
        {
            Logger.LogInfo(
                LogPrefix +
                "PATCH READY: CharacterSpawner.Update");

            return true;
        }

        /// <summary>
        /// CharacterSpawner가 실행되는 동안 현재 씬과
        /// 모든 플레이어의 생성 상태를 확인합니다.
        /// </summary>
        [HarmonyPostfix]
        private static void Postfix(
            CharacterSpawner __instance)
        {
            ResetStateWhenSceneChanged();

            if (__instance == null)
            {
                return;
            }

            if (!PhotonNetwork.InRoom ||
                PhotonNetwork.CurrentRoom == null)
            {
                return;
            }

            /*
             * Airport에서는 달걀을 지급하지 않습니다.
             *
             * 이전 게임에서 사용한 Room Property가 남아 있을 수 있으므로
             * Airport에 들어오면 다음 게임을 위해 초기화합니다.
             */
            if (!GameHandler.IsOnIsland)
            {
                ResetRoomPropertiesInAirport();
                return;
            }

            /*
             * 첫 맵인 Beach 구간에서만 지급하고 장착합니다.
             */
            if (MapHandler.CurrentSegmentNumber !=
                Segment.Beach)
            {
                return;
            }

            /*
             * 호스트가 저장한 대상 플레이어와 슬롯을 확인합니다.
             *
             * 선택된 플레이어의 클라이언트에서만
             * 해당 NestEgg 슬롯을 즉시 장착합니다.
             */
            TryStartLocalEquipRoutine(
                __instance);

            /*
             * 이전 호스트가 이미 지급했다면
             * 새로운 호스트가 다시 지급하지 않습니다.
             */
            if (IsEggAlreadyGrantedInRoom())
            {
                eggGranted = true;
                return;
            }

            if (!PhotonNetwork.IsMasterClient)
            {
                return;
            }

            if (eggGranted ||
                routineStarted)
            {
                return;
            }

            routineStarted = true;

            int sceneHandle =
                SceneManager
                    .GetActiveScene()
                    .handle;

            __instance.StartCoroutine(
                WaitForAllPlayersAndGrantEgg(
                    sceneHandle));
        }

        /// <summary>
        /// Photon 방에 들어온 모든 플레이어의 Character와 Player가
        /// 생성될 때까지 기다린 뒤 무작위 한 명에게 지급합니다.
        /// </summary>
        private static IEnumerator
            WaitForAllPlayersAndGrantEgg(
                int startedSceneHandle)
        {
            float stableTime =
                0f;

            int stablePlayerCount =
                -1;

            Logger.LogInfo(
                LogPrefix +
                "Waiting for all connected players " +
                "to finish spawning.");

            while (true)
            {
                if (!CanContinueWaiting(
                        startedSceneHandle))
                {
                    routineStarted = false;
                    yield break;
                }

                if (IsEggAlreadyGrantedInRoom())
                {
                    eggGranted = true;
                    routineStarted = false;
                    yield break;
                }

                List<Character> readyCharacters;
                int roomPlayerCount;

                bool allPlayersReady =
                    TryGetAllSpawnedCharacters(
                        out readyCharacters,
                        out roomPlayerCount);

                if (!allPlayersReady)
                {
                    stableTime = 0f;
                    stablePlayerCount = -1;

                    yield return null;
                    continue;
                }

                if (roomPlayerCount !=
                    stablePlayerCount)
                {
                    stablePlayerCount =
                        roomPlayerCount;

                    stableTime =
                        0f;

                    if (lastLoggedReadyCount !=
                        roomPlayerCount)
                    {
                        lastLoggedReadyCount =
                            roomPlayerCount;

                        Logger.LogInfo(
                            LogPrefix +
                            "All current player characters are ready." +
                            " | PlayerCount=" +
                            roomPlayerCount);
                    }

                    yield return null;
                    continue;
                }

                stableTime +=
                    Time.unscaledDeltaTime;

                if (stableTime <
                    RequiredStableTime)
                {
                    yield return null;
                    continue;
                }

                break;
            }

            /*
             * 안정화 판정 직후 한 번 더 전체 인원을 확인합니다.
             */
            List<Character> finalCharacters;
            int finalPlayerCount;

            if (!TryGetAllSpawnedCharacters(
                    out finalCharacters,
                    out finalPlayerCount))
            {
                routineStarted = false;
                yield break;
            }

            if (finalCharacters.Count == 0)
            {
                Logger.LogError(
                    LogPrefix +
                    "Egg grant failed: " +
                    "no spawned character was found.");

                routineStarted = false;
                yield break;
            }

            Item nestEggPrefab;

            if (!TryGetNestEggPrefab(
                    out nestEggPrefab))
            {
                Logger.LogError(
                    LogPrefix +
                    "Egg grant failed: " +
                    "NestEgg was not found in ItemDatabase.");

                routineStarted = false;
                yield break;
            }

            /*
             * PEAK의 손 장착 시스템은 ItemSlot을 기반으로 작동합니다.
             *
             * 따라서 달걀을 보관만 하는 것이 아니라,
             * 빈 슬롯이 있는 플레이어를 선정한 뒤
             * 해당 슬롯을 즉시 선택하여 손에 들게 합니다.
             */
            List<Character> eligibleCharacters =
                new List<Character>();

            for (int i = 0;
                 i < finalCharacters.Count;
                 i++)
            {
                Character character =
                    finalCharacters[i];

                if (character == null ||
                    character.player == null ||
                    character.refs == null ||
                    character.refs.items == null)
                {
                    continue;
                }

                if (!character.player.HasEmptySlot(
                        nestEggPrefab.itemID))
                {
                    Logger.LogWarning(
                        LogPrefix +
                        "Player excluded because inventory is full." +
                        " | Player=" +
                        GetCharacterName(character));

                    continue;
                }

                eligibleCharacters.Add(
                    character);
            }

            if (eligibleCharacters.Count == 0)
            {
                Logger.LogError(
                    LogPrefix +
                    "Egg grant failed: " +
                    "all player inventories are full.");

                routineStarted = false;
                yield break;
            }

            /*
             * 랜덤값은 호스트에서만 결정합니다.
             */
            int randomIndex =
                UnityEngine.Random.Range(
                    0,
                    eligibleCharacters.Count);

            Character selectedCharacter =
                eligibleCharacters[randomIndex];

            int actorNumber =
                GetActorNumber(
                    selectedCharacter);

            if (actorNumber < 0)
            {
                Logger.LogError(
                    LogPrefix +
                    "Egg grant failed: " +
                    "selected player ActorNumber was invalid.");

                routineStarted = false;
                yield break;
            }

            ItemSlot addedSlot;

            bool addSucceeded =
                selectedCharacter.player.AddItem(
                    nestEggPrefab.itemID,
                    null,
                    out addedSlot);

            if (!addSucceeded ||
                addedSlot == null)
            {
                Logger.LogError(
                    LogPrefix +
                    "NestEgg could not be added to " +
                    GetCharacterName(
                        selectedCharacter) +
                    "'s item slot.");

                routineStarted = false;
                yield break;
            }

            /*
             * 다음 정보를 Room Property에 한 번에 기록합니다.
             *
             * - 지급 완료 여부
             * - 선택된 플레이어 ActorNumber
             * - 달걀이 추가된 슬롯 번호
             *
             * 선택된 플레이어의 클라이언트는 이 정보를 확인한 뒤
             * 해당 슬롯에 NestEgg가 동기화될 때까지 기다렸다가
             * EquipSlot을 실행합니다.
             */
            SetRoomEggAssignment(
                true,
                actorNumber,
                addedSlot.itemSlotID);

            eggGranted = true;
            routineStarted = false;

            Logger.LogWarning(
                LogPrefix +
                "NestEgg assigned to one random player." +
                " The selected player will hold it immediately." +
                " | SelectedPlayer=" +
                GetCharacterName(
                    selectedCharacter) +
                " | ActorNumber=" +
                actorNumber +
                " | ConnectedPlayers=" +
                finalPlayerCount +
                " | SlotID=" +
                addedSlot.itemSlotID +
                " | ItemID=" +
                nestEggPrefab.itemID);
        }

        /// <summary>
        /// 현재 클라이언트가 시작 달걀을 받을 플레이어인지 확인하고
        /// 자동 장착 코루틴을 시작합니다.
        /// </summary>
        private static void TryStartLocalEquipRoutine(
            CharacterSpawner characterSpawner)
        {
            if (characterSpawner == null ||
                localEquipCompleted ||
                localEquipRoutineStarted)
            {
                return;
            }

            if (PhotonNetwork.LocalPlayer == null)
            {
                return;
            }

            int targetActorNumber;
            byte targetSlotID;

            if (!TryGetRoomEggAssignment(
                    out targetActorNumber,
                    out targetSlotID))
            {
                return;
            }

            /*
             * 선택되지 않은 플레이어의 클라이언트에서는
             * 장착 작업을 실행하지 않습니다.
             */
            if (PhotonNetwork
                    .LocalPlayer
                    .ActorNumber !=
                targetActorNumber)
            {
                return;
            }

            localEquipRoutineStarted = true;

            int sceneHandle =
                SceneManager
                    .GetActiveScene()
                    .handle;

            characterSpawner.StartCoroutine(
                WaitForLocalEggAndEquip(
                    sceneHandle,
                    targetActorNumber,
                    targetSlotID));
        }

        /// <summary>
        /// 선택된 플레이어의 인벤토리 슬롯에 NestEgg 데이터가
        /// 네트워크로 동기화될 때까지 기다린 뒤 즉시 장착합니다.
        /// </summary>
        private static IEnumerator
            WaitForLocalEggAndEquip(
                int startedSceneHandle,
                int targetActorNumber,
                byte targetSlotID)
        {
            float nextEquipRequestTime =
                0f;

            Logger.LogInfo(
                LogPrefix +
                "This client was selected to receive the NestEgg." +
                " Waiting for slot synchronization." +
                " | ActorNumber=" +
                targetActorNumber +
                " | SlotID=" +
                targetSlotID);

            while (CanContinueLocalEquipWaiting(
                       startedSceneHandle))
            {
                int currentTargetActor;
                byte currentTargetSlot;

                if (!TryGetRoomEggAssignment(
                        out currentTargetActor,
                        out currentTargetSlot))
                {
                    localEquipRoutineStarted = false;
                    yield break;
                }

                /*
                 * 대기 중 Room Property의 대상이 변경되었다면
                 * 기존 장착 요청을 종료합니다.
                 */
                if (currentTargetActor !=
                        targetActorNumber ||
                    currentTargetSlot !=
                        targetSlotID)
                {
                    localEquipRoutineStarted = false;
                    yield break;
                }

                Character selectedCharacter;

                if (!PlayerHandler.TryGetCharacter(
                        targetActorNumber,
                        out selectedCharacter))
                {
                    yield return null;
                    continue;
                }

                if (selectedCharacter == null ||
                    !selectedCharacter.IsLocal ||
                    selectedCharacter.data == null ||
                    selectedCharacter.player == null ||
                    selectedCharacter.refs == null ||
                    selectedCharacter.refs.items == null)
                {
                    yield return null;
                    continue;
                }

                ItemSlot eggSlot =
                    selectedCharacter
                        .player
                        .GetItemSlot(
                            targetSlotID);

                /*
                 * Room Property가 먼저 도착하고
                 * 인벤토리 Sync RPC가 나중에 도착할 수 있으므로,
                 * 실제 슬롯에 NestEgg가 들어올 때까지 기다립니다.
                 */
                if (eggSlot == null ||
                    eggSlot.IsEmpty() ||
                    eggSlot.prefab == null ||
                    !IsNestEggName(
                        eggSlot.prefab.gameObject.name))
                {
                    yield return null;
                    continue;
                }

                /*
                 * 이미 해당 NestEgg를 손에 들고 있다면 완료합니다.
                 */
                if (IsNestEggHeldByCharacter(
                        selectedCharacter,
                        targetSlotID))
                {
                    localEquipCompleted = true;
                    localEquipRoutineStarted = false;

                    Logger.LogWarning(
                        LogPrefix +
                        "NestEgg is now held by the selected player." +
                        " | Player=" +
                        GetCharacterName(
                            selectedCharacter) +
                        " | ActorNumber=" +
                        targetActorNumber +
                        " | SlotID=" +
                        targetSlotID);

                    yield break;
                }

                /*
                 * 장착은 선택된 플레이어 자신의 클라이언트에서 실행합니다.
                 *
                 * CharacterItems.EquipSlot이 PEAK 원본 네트워크 장착,
                 * ItemState.Held 설정 및 손 고정을 처리합니다.
                 */
                if (Time.unscaledTime >=
                    nextEquipRequestTime)
                {
                    nextEquipRequestTime =
                        Time.unscaledTime +
                        EquipRetryInterval;

                    selectedCharacter
                        .refs
                        .items
                        .EquipSlot(
                            Optionable<byte>.Some(
                                targetSlotID));

                    Logger.LogInfo(
                        LogPrefix +
                        "Immediate hand equip requested." +
                        " | Player=" +
                        GetCharacterName(
                            selectedCharacter) +
                        " | ActorNumber=" +
                        targetActorNumber +
                        " | SlotID=" +
                        targetSlotID);
                }

                yield return null;
            }

            localEquipRoutineStarted = false;
        }

        /// <summary>
        /// 지정된 캐릭터가 해당 슬롯의 NestEgg를
        /// 실제로 손에 들고 있는지 확인합니다.
        /// </summary>
        private static bool IsNestEggHeldByCharacter(
            Character character,
            byte slotID)
        {
            if (character == null ||
                character.data == null ||
                character.refs == null ||
                character.refs.items == null)
            {
                return false;
            }

            Item currentItem =
                character.data.currentItem;

            if (currentItem == null ||
                currentItem.itemState !=
                    ItemState.Held ||
                !IsNestEggName(
                    currentItem.gameObject.name))
            {
                return false;
            }

            Optionable<byte> currentSelectedSlot =
                character
                    .refs
                    .items
                    .currentSelectedSlot;

            if (!currentSelectedSlot.IsSome)
            {
                return false;
            }

            return currentSelectedSlot.Value ==
                   slotID;
        }

        /// <summary>
        /// 로컬 자동 장착 작업을 계속할 수 있는지 확인합니다.
        /// </summary>
        private static bool
            CanContinueLocalEquipWaiting(
                int startedSceneHandle)
        {
            if (SceneManager
                    .GetActiveScene()
                    .handle !=
                startedSceneHandle)
            {
                return false;
            }

            if (!PhotonNetwork.InRoom ||
                PhotonNetwork.CurrentRoom == null)
            {
                return false;
            }

            if (!GameHandler.IsOnIsland)
            {
                return false;
            }

            return MapHandler.CurrentSegmentNumber ==
                   Segment.Beach;
        }

        /// <summary>
        /// 현재 Photon 방에 접속한 모든 플레이어가
        /// Character, Player, inventory 참조까지 생성됐는지 확인합니다.
        /// </summary>
        private static bool
            TryGetAllSpawnedCharacters(
                out List<Character> characters,
                out int roomPlayerCount)
        {
            characters =
                new List<Character>();

            Photon.Realtime.Player[] roomPlayers =
                PhotonNetwork.PlayerList;

            roomPlayerCount =
                roomPlayers != null
                    ? roomPlayers.Length
                    : 0;

            if (roomPlayers == null ||
                roomPlayers.Length == 0)
            {
                return false;
            }

            for (int i = 0;
                 i < roomPlayers.Length;
                 i++)
            {
                Photon.Realtime.Player roomPlayer =
                    roomPlayers[i];

                if (roomPlayer == null)
                {
                    return false;
                }

                Character character;

                if (!PlayerHandler.TryGetCharacter(
                        roomPlayer.ActorNumber,
                        out character))
                {
                    return false;
                }

                if (character == null ||
                    character.data == null ||
                    character.refs == null ||
                    character.refs.items == null ||
                    character.player == null)
                {
                    return false;
                }

                characters.Add(
                    character);
            }

            return characters.Count ==
                   roomPlayers.Length;
        }

        /// <summary>
        /// 첫 게임 맵에서 지급 대기 작업을
        /// 계속할 수 있는지 확인합니다.
        /// </summary>
        private static bool CanContinueWaiting(
            int startedSceneHandle)
        {
            if (SceneManager
                    .GetActiveScene()
                    .handle !=
                startedSceneHandle)
            {
                return false;
            }

            if (!PhotonNetwork.InRoom ||
                PhotonNetwork.CurrentRoom == null ||
                !PhotonNetwork.IsMasterClient)
            {
                return false;
            }

            if (!GameHandler.IsOnIsland)
            {
                return false;
            }

            return MapHandler.CurrentSegmentNumber ==
                   Segment.Beach;
        }

        /// <summary>
        /// ItemDatabase 또는 Resources에서
        /// 실제 NestEgg Item 프리팹을 찾습니다.
        /// </summary>
        private static bool TryGetNestEggPrefab(
            out Item nestEggPrefab)
        {
            nestEggPrefab =
                null;

            ItemDatabase itemDatabase =
                SingletonAsset<ItemDatabase>.Instance;

            if (itemDatabase != null &&
                itemDatabase.itemLookup != null)
            {
                foreach (
                    KeyValuePair<ushort, Item> entry
                    in itemDatabase.itemLookup)
                {
                    Item item =
                        entry.Value;

                    if (item == null)
                    {
                        continue;
                    }

                    if (!IsNestEggName(
                            item.gameObject.name))
                    {
                        continue;
                    }

                    nestEggPrefab =
                        item;

                    return true;
                }
            }

            /*
             * ItemDatabase 검색이 실패한 경우
             * PEAK의 원본 Resources 경로를 사용합니다.
             */
            GameObject resourcePrefab =
                Resources.Load<GameObject>(
                    "0_Items/" +
                    TargetPrefabName);

            if (resourcePrefab == null)
            {
                return false;
            }

            nestEggPrefab =
                resourcePrefab.GetComponent<Item>();

            if (nestEggPrefab == null)
            {
                nestEggPrefab =
                    resourcePrefab
                        .GetComponentInChildren<Item>(
                            true);
            }

            return nestEggPrefab != null;
        }

        private static bool IsNestEggName(
            string objectName)
        {
            return string.Equals(
                NormalizeObjectName(
                    objectName),
                TargetPrefabName,
                StringComparison.OrdinalIgnoreCase);
        }

        private static string NormalizeObjectName(
            string objectName)
        {
            if (string.IsNullOrEmpty(
                    objectName))
            {
                return string.Empty;
            }

            string normalized =
                objectName.Trim();

            const string cloneSuffix =
                "(Clone)";

            while (normalized.EndsWith(
                       cloneSuffix,
                       StringComparison.OrdinalIgnoreCase))
            {
                normalized =
                    normalized.Substring(
                        0,
                        normalized.Length -
                        cloneSuffix.Length)
                    .Trim();
            }

            return normalized;
        }

        /// <summary>
        /// 이전 게임에서 남아 있는 시작 달걀 정보를
        /// Airport에서 초기화합니다.
        /// </summary>
        private static void ResetRoomPropertiesInAirport()
        {
            if (airportPropertyReset ||
                !PhotonNetwork.IsMasterClient ||
                PhotonNetwork.CurrentRoom == null)
            {
                return;
            }

            airportPropertyReset =
                true;

            SetRoomEggAssignment(
                false,
                -1,
                byte.MaxValue);

            Logger.LogInfo(
                LogPrefix +
                "Airport detected. " +
                "Start egg room state reset.");
        }

        /// <summary>
        /// Photon Room Property에 기록된
        /// 지급 여부를 확인합니다.
        /// </summary>
        private static bool
            IsEggAlreadyGrantedInRoom()
        {
            if (PhotonNetwork.CurrentRoom == null ||
                PhotonNetwork
                    .CurrentRoom
                    .CustomProperties == null)
            {
                return false;
            }

            if (!PhotonNetwork
                    .CurrentRoom
                    .CustomProperties
                    .ContainsKey(
                        RoomPropertyGrantedKey))
            {
                return false;
            }

            object propertyValue =
                PhotonNetwork
                    .CurrentRoom
                    .CustomProperties[
                        RoomPropertyGrantedKey];

            if (!(propertyValue is bool))
            {
                return false;
            }

            return (bool)propertyValue;
        }

        /// <summary>
        /// 시작 달걀을 받을 플레이어와 슬롯 정보를 읽습니다.
        /// </summary>
        private static bool TryGetRoomEggAssignment(
            out int actorNumber,
            out byte slotID)
        {
            actorNumber =
                -1;

            slotID =
                byte.MaxValue;

            if (!IsEggAlreadyGrantedInRoom() ||
                PhotonNetwork.CurrentRoom == null ||
                PhotonNetwork
                    .CurrentRoom
                    .CustomProperties == null)
            {
                return false;
            }

            PhotonHashtable properties =
                PhotonNetwork
                    .CurrentRoom
                    .CustomProperties;

            if (!properties.ContainsKey(
                    RoomPropertyActorKey) ||
                !properties.ContainsKey(
                    RoomPropertySlotKey))
            {
                return false;
            }

            object actorValue =
                properties[
                    RoomPropertyActorKey];

            object slotValue =
                properties[
                    RoomPropertySlotKey];

            if (!(actorValue is int) ||
                !(slotValue is int))
            {
                return false;
            }

            actorNumber =
                (int)actorValue;

            int slotNumber =
                (int)slotValue;

            if (actorNumber < 0 ||
                slotNumber < 0 ||
                slotNumber >
                    byte.MaxValue)
            {
                actorNumber = -1;
                slotID = byte.MaxValue;

                return false;
            }

            slotID =
                (byte)slotNumber;

            return true;
        }

        /// <summary>
        /// 호스트 변경 후에도 지급 및 자동 장착 대상이 유지되도록
        /// Photon Room Property에 결과를 기록합니다.
        /// </summary>
        private static void SetRoomEggAssignment(
            bool granted,
            int actorNumber,
            byte slotID)
        {
            if (!PhotonNetwork.InRoom ||
                PhotonNetwork.CurrentRoom == null ||
                !PhotonNetwork.IsMasterClient)
            {
                return;
            }

            PhotonHashtable properties =
                new PhotonHashtable();

            properties[
                RoomPropertyGrantedKey] =
                granted;

            properties[
                RoomPropertyActorKey] =
                actorNumber;

            properties[
                RoomPropertySlotKey] =
                granted
                    ? (int)slotID
                    : -1;

            PhotonNetwork
                .CurrentRoom
                .SetCustomProperties(
                    properties);
        }

        private static string GetCharacterName(
            Character character)
        {
            if (character == null)
            {
                return "Unknown";
            }

            if (character.photonView != null &&
                character.photonView.Owner != null)
            {
                return character
                    .photonView
                    .Owner
                    .NickName;
            }

            return character.gameObject.name;
        }

        private static int GetActorNumber(
            Character character)
        {
            if (character == null ||
                character.photonView == null ||
                character.photonView.Owner == null)
            {
                return -1;
            }

            return character
                .photonView
                .Owner
                .ActorNumber;
        }

        /// <summary>
        /// 씬이 바뀌면 로컬 대기 및 자동 장착 상태를 초기화합니다.
        /// Room Property는 Airport에서 별도로 초기화합니다.
        /// </summary>
        private static void ResetStateWhenSceneChanged()
        {
            int sceneHandle =
                SceneManager
                    .GetActiveScene()
                    .handle;

            if (currentSceneHandle ==
                sceneHandle)
            {
                return;
            }

            currentSceneHandle =
                sceneHandle;

            routineStarted =
                false;

            eggGranted =
                false;

            airportPropertyReset =
                false;

            localEquipRoutineStarted =
                false;

            localEquipCompleted =
                false;

            lastLoggedReadyCount =
                -1;

            Logger.LogInfo(
                LogPrefix +
                "Scene state reset." +
                " | Scene=" +
                SceneManager
                    .GetActiveScene()
                    .name);
        }
    }

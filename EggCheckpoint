using System;
using System.Collections.Generic;
using BepInEx.Logging;
using HarmonyLib;
using UnityEngine;
using UnityEngine.SceneManagement;

namespace Sapphire009.WatchEgg
{
    /// <summary>
    /// NestEgg 전용 3차원 구형 체크포인트입니다.
    ///
    /// 마지막 체크포인트를 중심으로 반지름 25m의 구형 범위를 계산합니다.
    /// 실제 달걀 위치가 범위 밖으로 나가고 안전한 바닥 위치를 찾으면
    /// 해당 위치를 새로운 체크포인트로 저장합니다.
    ///
    /// X, Y, Z를 모두 계산하므로 수평, 수직, 대각선 이동이
    /// 모두 동일하게 적용됩니다.
    ///
    /// 달걀 생성은 YSpawn.cs에서 처리합니다.
    /// </summary>
    [DisallowMultipleComponent]
    public sealed class EggCheckpoint : MonoBehaviour
    {
        public const string DeveloperName =
            "Sapphire009";

        public const string TargetPrefabName =
            "NestEgg";

        /// <summary>
        /// 마지막 체크포인트를 중심으로 하는
        /// 3차원 구형 범위의 반지름입니다.
        /// </summary>
        public const float TargetCheckpointDistance =
            25f;

        private const float TargetCheckpointDistanceSquared =
            TargetCheckpointDistance *
            TargetCheckpointDistance;

        private const float MinimumGroundNormalY =
            0.55f;

        private const float GroundCastStartHeight =
            2.5f;

        private const float GroundCastDistance =
            6f;

        private const float InitialGroundCastDistance =
            12f;

        private const float GroundCastRadius =
            0.18f;

        private const float GroundSurfacePadding =
            0.015f;

        private const float MaximumEggGroundDistanceFromHolder =
            1.6f;

        private const string LogPrefix =
            "[EggCheckpoint] ";

        private static readonly ManualLogSource Logger =
            BepInEx.Logging.Logger.CreateLogSource(
                "WatchEgg.EggCheckpoint");

        private static readonly HashSet<int> CountedBrokenViewIds =
            new HashSet<int>();

        private static int activeSceneHandle =
            int.MinValue;

        public static bool HasCheckpoint
        {
            get;
            private set;
        }

        public static Vector3 CheckpointPosition
        {
            get;
            private set;
        }

        public static Quaternion CheckpointRotation
        {
            get;
            private set;
        }

        public static int CheckpointNumber
        {
            get;
            private set;
        }

        public static int BrokenEggCount
        {
            get;
            private set;
        }

        public static float DistanceFromLastCheckpoint
        {
            get;
            private set;
        }

        private Item item;

        private Quaternion eggRestRotation;

        private float pivotToEggBottom =
            0.2f;

        private void Awake()
        {
            ResetStaticDataWhenSceneChanged();

            item =
                GetComponent<Item>();

            if (!IsNestEgg(item))
            {
                enabled =
                    false;

                return;
            }

            eggRestRotation =
                transform.rotation;

            CacheEggBottomOffset();
            CacheInitialCheckpoint();

            Logger.LogInfo(
                LogPrefix +
                "Attached to " +
                item.gameObject.name +
                " | Radius=" +
                TargetCheckpointDistance +
                " | DistanceMode=EggToCheckpoint3DSphere");
        }

        private void Update()
        {
            ResetStaticDataWhenSceneChanged();

            if (item == null)
            {
                return;
            }

            if (!HasCheckpoint)
            {
                CacheInitialCheckpoint();

                if (!HasCheckpoint)
                {
                    DistanceFromLastCheckpoint =
                        0f;

                    return;
                }
            }

            Vector3 checkpointToEgg =
                transform.position -
                CheckpointPosition;

            float distanceSquared =
                checkpointToEgg.sqrMagnitude;

            DistanceFromLastCheckpoint =
                Mathf.Sqrt(distanceSquared);

            /*
             * 마지막 체크포인트 중심의 반지름 25m
             * 3차원 구형 범위 안이면 기존 체크포인트를 유지합니다.
             */
            if (distanceSquared <
                TargetCheckpointDistanceSquared)
            {
                return;
            }

            Vector3 safeCheckpointPosition;

            if (!TryGetSafeCheckpointPosition(
                    out safeCheckpointPosition))
            {
                return;
            }

            Vector3 checkpointToSafePosition =
                safeCheckpointPosition -
                CheckpointPosition;

            /*
             * 실제 저장될 안전한 스폰 위치도
             * 기존 체크포인트에서 25m 이상 떨어져 있어야 합니다.
             */
            if (checkpointToSafePosition.sqrMagnitude <
                TargetCheckpointDistanceSquared)
            {
                return;
            }

            SaveCheckpoint(
                safeCheckpointPosition);
        }

        private bool TryGetSafeCheckpointPosition(
            out Vector3 result)
        {
            result =
                Vector3.zero;

            if (item.itemState ==
                    ItemState.Held &&
                item.holderCharacter != null)
            {
                return TryGetSafeHeldEggPosition(
                    item.holderCharacter,
                    out result);
            }

            return TryGetGroundPositionBelowEgg(
                InitialGroundCastDistance,
                out result);
        }

        private bool TryGetSafeHeldEggPosition(
            Character holder,
            out Vector3 result)
        {
            result =
                Vector3.zero;

            if (!IsHolderOnSafeGround(
                    holder))
            {
                return false;
            }

            RaycastHit groundHit;

            if (TryCastGroundBelowHeldEgg(
                    holder,
                    out groundHit))
            {
                result =
                    groundHit.point +
                    Vector3.up *
                    (pivotToEggBottom +
                     GroundSurfacePadding);

                return true;
            }

            if (!TryCastGroundAtHolder(
                    holder,
                    out groundHit))
            {
                return false;
            }

            result =
                groundHit.point +
                Vector3.up *
                (pivotToEggBottom +
                 GroundSurfacePadding);

            return true;
        }

        private static bool IsHolderOnSafeGround(
            Character holder)
        {
            if (holder == null ||
                holder.data == null)
            {
                return false;
            }

            if (!holder.data.isGrounded)
            {
                return false;
            }

            if (holder.data.isClimbing ||
                holder.data.isRopeClimbing ||
                holder.data.isVineClimbing)
            {
                return false;
            }

            if (holder.data.dead ||
                holder.data.fullyPassedOut)
            {
                return false;
            }

            if (holder.data.groundNormal.y <
                MinimumGroundNormalY)
            {
                return false;
            }

            return true;
        }

        private bool TryCastGroundBelowHeldEgg(
            Character holder,
            out RaycastHit groundHit)
        {
            groundHit =
                default(RaycastHit);

            if (holder == null ||
                holder.data == null)
            {
                return false;
            }

            Vector3 holderGroundPosition =
                holder.data.groundPos;

            Vector3 castOrigin =
                new Vector3(
                    transform.position.x,
                    holderGroundPosition.y +
                    GroundCastStartHeight,
                    transform.position.z);

            if (!Physics.SphereCast(
                    castOrigin,
                    GroundCastRadius,
                    Vector3.down,
                    out groundHit,
                    GroundCastDistance,
                    HelperFunctions.GetMask(
                        HelperFunctions.LayerType.TerrainMap),
                    QueryTriggerInteraction.Ignore))
            {
                return false;
            }

            if (groundHit.normal.y <
                MinimumGroundNormalY)
            {
                return false;
            }

            Vector3 horizontalDifference =
                groundHit.point -
                holderGroundPosition;

            horizontalDifference.y =
                0f;

            return horizontalDifference.sqrMagnitude <=
                   MaximumEggGroundDistanceFromHolder *
                   MaximumEggGroundDistanceFromHolder;
        }

        private static bool TryCastGroundAtHolder(
            Character holder,
            out RaycastHit groundHit)
        {
            groundHit =
                default(RaycastHit);

            if (holder == null ||
                holder.data == null)
            {
                return false;
            }

            Vector3 castOrigin =
                holder.data.groundPos +
                Vector3.up *
                GroundCastStartHeight;

            if (!Physics.SphereCast(
                    castOrigin,
                    GroundCastRadius,
                    Vector3.down,
                    out groundHit,
                    GroundCastDistance,
                    HelperFunctions.GetMask(
                        HelperFunctions.LayerType.TerrainMap),
                    QueryTriggerInteraction.Ignore))
            {
                return false;
            }

            return groundHit.normal.y >=
                   MinimumGroundNormalY;
        }

        private bool TryGetGroundPositionBelowEgg(
            float castDistance,
            out Vector3 result)
        {
            result =
                Vector3.zero;

            Vector3 castOrigin =
                transform.position +
                Vector3.up *
                GroundCastStartHeight;

            RaycastHit groundHit;

            if (!Physics.SphereCast(
                    castOrigin,
                    GroundCastRadius,
                    Vector3.down,
                    out groundHit,
                    castDistance,
                    HelperFunctions.GetMask(
                        HelperFunctions.LayerType.TerrainMap),
                    QueryTriggerInteraction.Ignore))
            {
                return false;
            }

            if (groundHit.normal.y <
                MinimumGroundNormalY)
            {
                return false;
            }

            result =
                groundHit.point +
                Vector3.up *
                (pivotToEggBottom +
                 GroundSurfacePadding);

            return true;
        }

        private void SaveCheckpoint(
            Vector3 newCheckpointPosition)
        {
            Vector3 previousCheckpointPosition =
                CheckpointPosition;

            float completedDistance =
                Vector3.Distance(
                    previousCheckpointPosition,
                    newCheckpointPosition);

            CheckpointPosition =
                newCheckpointPosition;

            CheckpointRotation =
                eggRestRotation;

            HasCheckpoint =
                true;

            CheckpointNumber++;

            DistanceFromLastCheckpoint =
                0f;

            Logger.LogWarning(
                LogPrefix +
                "New 3D sphere checkpoint saved." +
                " | Number=" +
                CheckpointNumber +
                " | Distance=" +
                completedDistance +
                " | PreviousPosition=" +
                previousCheckpointPosition +
                " | NewPosition=" +
                CheckpointPosition);
        }

        private void CacheInitialCheckpoint()
        {
            if (HasCheckpoint)
            {
                return;
            }

            Vector3 initialPosition;

            if (!TryGetGroundPositionBelowEgg(
                    InitialGroundCastDistance,
                    out initialPosition))
            {
                if (item != null &&
                    item.itemState ==
                        ItemState.Held &&
                    item.holderCharacter != null)
                {
                    if (!TryGetSafeHeldEggPosition(
                            item.holderCharacter,
                            out initialPosition))
                    {
                        return;
                    }
                }
                else
                {
                    return;
                }
            }

            CheckpointPosition =
                initialPosition;

            CheckpointRotation =
                eggRestRotation;

            HasCheckpoint =
                true;

            CheckpointNumber =
                1;

            DistanceFromLastCheckpoint =
                0f;

            Logger.LogWarning(
                LogPrefix +
                "Initial checkpoint cached." +
                " | Position=" +
                CheckpointPosition);
        }

        private void CacheEggBottomOffset()
        {
            Collider[] colliders =
                GetComponentsInChildren<Collider>(
                    true);

            float lowestPoint =
                float.PositiveInfinity;

            bool foundBounds =
                false;

            for (int i = 0;
                 i < colliders.Length;
                 i++)
            {
                Collider currentCollider =
                    colliders[i];

                if (currentCollider == null ||
                    !currentCollider.enabled ||
                    currentCollider.isTrigger)
                {
                    continue;
                }

                Bounds bounds =
                    currentCollider.bounds;

                if (bounds.size.sqrMagnitude <=
                    0.0001f)
                {
                    continue;
                }

                if (bounds.min.y <
                    lowestPoint)
                {
                    lowestPoint =
                        bounds.min.y;
                }

                foundBounds =
                    true;
            }

            if (!foundBounds)
            {
                Renderer[] renderers =
                    GetComponentsInChildren<Renderer>(
                        true);

                for (int i = 0;
                     i < renderers.Length;
                     i++)
                {
                    Renderer currentRenderer =
                        renderers[i];

                    if (currentRenderer == null)
                    {
                        continue;
                    }

                    Bounds bounds =
                        currentRenderer.bounds;

                    if (bounds.size.sqrMagnitude <=
                        0.0001f)
                    {
                        continue;
                    }

                    if (bounds.min.y <
                        lowestPoint)
                    {
                        lowestPoint =
                            bounds.min.y;
                    }

                    foundBounds =
                        true;
                }
            }

            if (!foundBounds)
            {
                pivotToEggBottom =
                    0.2f;

                return;
            }

            float calculatedOffset =
                transform.position.y -
                lowestPoint;

            if (calculatedOffset <=
                    0.01f ||
                calculatedOffset >=
                    3f)
            {
                pivotToEggBottom =
                    0.2f;

                return;
            }

            pivotToEggBottom =
                calculatedOffset;
        }

        public static bool TryGetCheckpoint(
            out Vector3 position,
            out Quaternion rotation)
        {
            position =
                CheckpointPosition;

            rotation =
                CheckpointRotation;

            return HasCheckpoint;
        }

        public static void ResetCheckpoint()
        {
            HasCheckpoint =
                false;

            CheckpointPosition =
                Vector3.zero;

            CheckpointRotation =
                Quaternion.identity;

            CheckpointNumber =
                0;

            BrokenEggCount =
                0;

            DistanceFromLastCheckpoint =
                0f;

            CountedBrokenViewIds.Clear();
        }

        private static void ResetStaticDataWhenSceneChanged()
        {
            Scene activeScene =
                SceneManager.GetActiveScene();

            if (activeSceneHandle ==
                activeScene.handle)
            {
                return;
            }

            activeSceneHandle =
                activeScene.handle;

            ResetCheckpoint();

            Logger.LogInfo(
                LogPrefix +
                "Scene changed. Checkpoint data reset." +
                " | Scene=" +
                activeScene.name);
        }

        public static bool IsNestEgg(
            Item targetItem)
        {
            if (targetItem == null)
            {
                return false;
            }

            return IsNestEggName(
                targetItem.gameObject.name);
        }

        public static bool IsNestEggName(
            string objectName)
        {
            return string.Equals(
                NormalizePrefabName(
                    objectName),
                TargetPrefabName,
                StringComparison.OrdinalIgnoreCase);
        }

        private static string NormalizePrefabName(
            string objectName)
        {
            if (string.IsNullOrEmpty(
                    objectName))
            {
                return string.Empty;
            }

            string normalized =
                objectName.Trim();

            const string cloneSuffix =
                "(Clone)";

            while (normalized.EndsWith(
                cloneSuffix,
                StringComparison.OrdinalIgnoreCase))
            {
                normalized =
                    normalized.Substring(
                        0,
                        normalized.Length -
                        cloneSuffix.Length);

                normalized =
                    normalized.Trim();
            }

            return normalized;
        }

        [HarmonyPatch(
            typeof(Item),
            "Awake")]
        private static class ItemAwakePatch
        {
            [HarmonyPostfix]
            private static void Postfix(
                Item __instance)
            {
                if (!IsNestEgg(
                        __instance))
                {
                    return;
                }

                if (__instance
                        .GetComponent<EggCheckpoint>() != null)
                {
                    return;
                }

                __instance.gameObject
                    .AddComponent<EggCheckpoint>();
            }
        }

        [HarmonyPatch(
            typeof(Breakable),
            nameof(Breakable.Break))]
        private static class BreakableBreakPatch
        {
            [HarmonyPrefix]
            private static void Prefix(
                Breakable __instance)
            {
                if (__instance == null)
                {
                    return;
                }

                Item brokenItem =
                    __instance.GetComponent<Item>();

                if (brokenItem == null)
                {
                    brokenItem =
                        __instance
                            .GetComponentInParent<Item>();
                }

                if (brokenItem == null)
                {
                    brokenItem =
                        __instance
                            .GetComponentInChildren<Item>(
                                true);
                }

                if (!IsNestEgg(
                        brokenItem))
                {
                    return;
                }

                int brokenEggId;

                if (brokenItem.photonView != null &&
                    brokenItem.photonView.ViewID > 0)
                {
                    brokenEggId =
                        brokenItem.photonView.ViewID;
                }
                else
                {
                    brokenEggId =
                        brokenItem.gameObject
                            .GetInstanceID();
                }

                if (CountedBrokenViewIds.Contains(
                        brokenEggId))
                {
                    return;
                }

                CountedBrokenViewIds.Add(
                    brokenEggId);

                BrokenEggCount++;

                Logger.LogWarning(
                    LogPrefix +
                    "NestEgg broken." +
                    " | BrokenCount=" +
                    BrokenEggCount +
                    " | EggID=" +
                    brokenEggId);
            }
        }
    }
}

using System.Collections;
using BepInEx.Logging;
using HarmonyLib;
using Photon.Pun;
using UnityEngine;
using UnityEngine.SceneManagement;

namespace Sapphire009.WatchEgg
{
    /// <summary>
    /// NestEgg가 깨지면 마지막 체크포인트에
    /// 새로운 NestEgg를 자동으로 생성합니다.
    ///
    /// Y키는 자동 생성이 실패했거나,
    /// 달걀이 맵 밖으로 사라진 상황에서 사용하는
    /// 비상 수동 복구 기능으로 유지합니다.
    ///
    /// 월드, 플레이어 인벤토리, 백팩에 NestEgg가 남아 있으면
    /// 중복 생성하지 않습니다.
    ///
    /// Developer: Sapphire009
    /// File: YSpawn.cs
    /// </summary>
    [HarmonyPatch(
        typeof(CharacterSpawner),
        "Update")]
    public static class YSpawn
    {
        public const string DeveloperName =
            "Sapphire009";

        public const string TargetPrefabName =
            "NestEgg";

        public const KeyCode EmergencySpawnKey =
            KeyCode.Y;

        private const string LogPrefix =
            "[YSpawn] ";

        /// <summary>
        /// 달걀이 깨진 직후 기존 오브젝트와 파손 효과가
        /// 정리될 때까지 기다리는 시간입니다.
        /// </summary>
        private const float AutomaticInitialDelay =
            1.25f;

        /// <summary>
        /// 깨진 NestEgg 오브젝트가 아직 남아 있으면
        /// 이 간격으로 다시 확인합니다.
        /// </summary>
        private const float AutomaticRetryInterval =
            0.5f;

        /// <summary>
        /// 자동 생성이 기존 달걀 제거를 기다리는 최대 시간입니다.
        ///
        /// 이 시간 안에 자동 복구하지 못하면
        /// Y키 비상 복구를 사용할 수 있습니다.
        /// </summary>
        private const float AutomaticRetryTimeout =
            10f;

        private const float EmergencyInputCooldown =
            0.75f;

        private static readonly ManualLogSource Logger =
            BepInEx.Logging.Logger.CreateLogSource(
                "WatchEgg.YSpawn");

        /// <summary>
        /// 새 NestEgg 생성까지 완료한 파손 횟수입니다.
        /// </summary>
        private static int handledBrokenEggCount;

        /// <summary>
        /// 자동 생성 시도를 이미 시작한 파손 횟수입니다.
        ///
        /// 동일 파손에 대해 자동 코루틴이 반복 생성되는 것을 막습니다.
        /// </summary>
        private static int automaticAttemptedBrokenEggCount;

        private static int currentSceneHandle =
            int.MinValue;

        private static int lastProcessedFrame =
            -1;

        private static float nextAllowedEmergencyInputTime;

        private static bool automaticRespawnRoutineRunning;

        [HarmonyPrepare]
        private static bool Prepare()
        {
            Logger.LogInfo(
                LogPrefix +
                "PATCH READY: CharacterSpawner.Update");

            return true;
        }

        /// <summary>
        /// 한 프레임에 한 번만 자동 복구와 Y키 입력을 처리합니다.
        /// </summary>
        [HarmonyPostfix]
        private static void Postfix(
            CharacterSpawner __instance)
        {
            ResetWhenSceneChanged();

            if (lastProcessedFrame ==
                Time.frameCount)
            {
                return;
            }

            lastProcessedFrame =
                Time.frameCount;

            /*
             * 깨짐 횟수가 증가하면 자동 복구를 시작합니다.
             */
            TryStartAutomaticRespawn(
                __instance);

            /*
             * Y키는 자동 복구와 별개의 비상 수동 복구입니다.
             */
            if (!Input.GetKeyDown(
                    EmergencySpawnKey))
            {
                return;
            }

            if (Time.unscaledTime <
                nextAllowedEmergencyInputTime)
            {
                return;
            }

            nextAllowedEmergencyInputTime =
                Time.unscaledTime +
                EmergencyInputCooldown;

            TrySpawnNestEgg(
                true,
                EggCheckpoint.BrokenEggCount);
        }

        /// <summary>
        /// BrokenEggCount 증가를 감지하여 자동 복구 코루틴을 시작합니다.
        /// </summary>
        private static void TryStartAutomaticRespawn(
            CharacterSpawner coroutineOwner)
        {
            if (coroutineOwner == null ||
                automaticRespawnRoutineRunning)
            {
                return;
            }

            if (!PhotonNetwork.InRoom ||
                PhotonNetwork.CurrentRoom == null ||
                !PhotonNetwork.IsMasterClient)
            {
                return;
            }

            if (!EggCheckpoint.HasCheckpoint)
            {
                return;
            }

            int brokenEggCount =
                EggCheckpoint.BrokenEggCount;

            if (brokenEggCount <= 0)
            {
                return;
            }

            /*
             * 이미 해당 파손에 대해 새 달걀을 생성했습니다.
             */
            if (brokenEggCount <=
                handledBrokenEggCount)
            {
                return;
            }

            /*
             * 해당 파손에 대해 자동 복구 시도를 이미 시작했습니다.
             */
            if (brokenEggCount <=
                automaticAttemptedBrokenEggCount)
            {
                return;
            }

            automaticAttemptedBrokenEggCount =
                brokenEggCount;

            automaticRespawnRoutineRunning =
                true;

            int startedSceneHandle =
                SceneManager
                    .GetActiveScene()
                    .handle;

            coroutineOwner.StartCoroutine(
                AutomaticRespawnRoutine(
                    startedSceneHandle,
                    brokenEggCount));
        }

        /// <summary>
        /// 깨진 NestEgg 오브젝트가 제거될 때까지 기다린 뒤
        /// 체크포인트에 새 NestEgg를 자동 생성합니다.
        /// </summary>
        private static IEnumerator AutomaticRespawnRoutine(
            int startedSceneHandle,
            int triggeringBrokenEggCount)
        {
            Logger.LogWarning(
                LogPrefix +
                "NestEgg break detected. " +
                "Automatic checkpoint respawn scheduled." +
                " | BrokenCount=" +
                triggeringBrokenEggCount);

            yield return
                new WaitForSecondsRealtime(
                    AutomaticInitialDelay);

            float timeoutTime =
                Time.unscaledTime +
                AutomaticRetryTimeout;

            while (true)
            {
                if (!CanContinueAutomaticRespawn(
                        startedSceneHandle))
                {
                    automaticRespawnRoutineRunning =
                        false;

                    yield break;
                }

                /*
                 * Y키나 다른 경로로 이미 복구했다면 종료합니다.
                 */
                if (handledBrokenEggCount >=
                    triggeringBrokenEggCount)
                {
                    automaticRespawnRoutineRunning =
                        false;

                    yield break;
                }

                string existingEggLocation;

                bool existingEggFound =
                    TryFindExistingNestEgg(
                        out existingEggLocation);

                if (!existingEggFound)
                {
                    bool spawnSucceeded =
                        TrySpawnNestEgg(
                            false,
                            triggeringBrokenEggCount);

                    if (spawnSucceeded)
                    {
                        automaticRespawnRoutineRunning =
                            false;

                        yield break;
                    }
                }

                if (Time.unscaledTime >=
                    timeoutTime)
                {
                    Logger.LogError(
                        LogPrefix +
                        "Automatic checkpoint respawn timed out." +
                        " Use Y for emergency recovery." +
                        " | BrokenCount=" +
                        triggeringBrokenEggCount +
                        " | ExistingEgg=" +
                        (
                            existingEggFound
                                ? existingEggLocation
                                : "None"
                        ));

                    automaticRespawnRoutineRunning =
                        false;

                    yield break;
                }

                yield return
                    new WaitForSecondsRealtime(
                        AutomaticRetryInterval);
            }
        }

        /// <summary>
        /// 자동 복구 코루틴을 계속 실행할 수 있는지 확인합니다.
        /// </summary>
        private static bool CanContinueAutomaticRespawn(
            int startedSceneHandle)
        {
            if (SceneManager
                    .GetActiveScene()
                    .handle !=
                startedSceneHandle)
            {
                return false;
            }

            if (!PhotonNetwork.InRoom ||
                PhotonNetwork.CurrentRoom == null ||
                !PhotonNetwork.IsMasterClient)
            {
                return false;
            }

            if (!EggCheckpoint.HasCheckpoint)
            {
                return false;
            }

            return true;
        }

        /// <summary>
        /// 체크포인트에 새 NestEgg를 생성합니다.
        ///
        /// emergencyRequest가 true이면 Y키 비상 복구입니다.
        /// 비상 복구는 BrokenEggCount가 증가하지 않았더라도
        /// 현재 NestEgg가 완전히 사라진 경우 사용할 수 있습니다.
        /// </summary>
        private static bool TrySpawnNestEgg(
            bool emergencyRequest,
            int triggeringBrokenEggCount)
        {
            string requestType =
                emergencyRequest
                    ? "Emergency Y"
                    : "Automatic";

            if (!PhotonNetwork.InRoom ||
                PhotonNetwork.CurrentRoom == null)
            {
                Logger.LogWarning(
                    LogPrefix +
                    requestType +
                    " spawn cancelled: " +
                    "Photon room is not ready.");

                return false;
            }

            /*
             * 한 명만 생성해야 하므로 호스트만 처리합니다.
             */
            if (!PhotonNetwork.IsMasterClient)
            {
                if (emergencyRequest)
                {
                    Logger.LogWarning(
                        LogPrefix +
                        "Emergency Y spawn cancelled: " +
                        "only the host can restore the egg.");
                }

                return false;
            }

            Character localCharacter =
                Character.localCharacter;

            if (localCharacter == null ||
                !localCharacter.IsLocal)
            {
                Logger.LogWarning(
                    LogPrefix +
                    requestType +
                    " spawn cancelled: " +
                    "local character is not ready.");

                return false;
            }

            Vector3 checkpointPosition;
            Quaternion checkpointRotation;

            if (!EggCheckpoint.TryGetCheckpoint(
                    out checkpointPosition,
                    out checkpointRotation))
            {
                Logger.LogWarning(
                    LogPrefix +
                    requestType +
                    " spawn cancelled: " +
                    "no checkpoint has been saved.");

                return false;
            }

            /*
             * 월드뿐 아니라 플레이어 인벤토리와 백팩도 검사합니다.
             *
             * 달걀이 다른 슬롯에 보관된 상태에서
             * 새 달걀이 중복 생성되는 것을 막습니다.
             */
            string existingEggLocation;

            if (TryFindExistingNestEgg(
                    out existingEggLocation))
            {
                if (emergencyRequest)
                {
                    Logger.LogWarning(
                        LogPrefix +
                        "Emergency Y spawn cancelled: " +
                        "a NestEgg still exists." +
                        " | Location=" +
                        existingEggLocation);
                }

                return false;
            }

            GameObject spawnedObject;

            try
            {
                spawnedObject =
                    PhotonNetwork.InstantiateItemRoom(
                        TargetPrefabName,
                        checkpointPosition,
                        checkpointRotation);
            }
            catch (System.Exception exception)
            {
                Logger.LogError(
                    LogPrefix +
                    requestType +
                    " Photon spawn failed." +
                    " | Exception=" +
                    exception);

                return false;
            }

            if (spawnedObject == null)
            {
                Logger.LogError(
                    LogPrefix +
                    requestType +
                    " spawn returned null.");

                return false;
            }

            PhotonView spawnedView =
                spawnedObject.GetComponent<PhotonView>();

            if (spawnedView == null)
            {
                Logger.LogError(
                    LogPrefix +
                    "Spawned NestEgg has no PhotonView.");

                PhotonNetwork.Destroy(
                    spawnedObject);

                return false;
            }

            /*
             * 호스트 화면에서 즉시 체크포인트 위치로 고정합니다.
             */
            spawnedObject.transform.SetPositionAndRotation(
                checkpointPosition,
                checkpointRotation);

            Rigidbody spawnedRigidbody =
                spawnedObject.GetComponent<Rigidbody>();

            if (spawnedRigidbody != null)
            {
                spawnedRigidbody.linearVelocity =
                    Vector3.zero;

                spawnedRigidbody.angularVelocity =
                    Vector3.zero;

                spawnedRigidbody.isKinematic =
                    true;

                spawnedRigidbody.Sleep();
            }

            /*
             * 모든 플레이어 화면에서 동일한 위치와
             * Kinematic 상태를 적용합니다.
             *
             * 플레이어가 직접 집기 전까지 굴러가거나 깨지지 않습니다.
             */
            spawnedView.RPC(
                "SetKinematicRPC",
                RpcTarget.AllBuffered,
                new object[]
                {
                    true,
                    checkpointPosition,
                    checkpointRotation
                });

            handledBrokenEggCount =
                Mathf.Max(
                    handledBrokenEggCount,
                    Mathf.Max(
                        triggeringBrokenEggCount,
                        EggCheckpoint.BrokenEggCount));

            Logger.LogWarning(
                LogPrefix +
                requestType +
                " NestEgg spawned at checkpoint." +
                " | BrokenCount=" +
                EggCheckpoint.BrokenEggCount +
                " | CheckpointNumber=" +
                EggCheckpoint.CheckpointNumber +
                " | Position=" +
                checkpointPosition +
                " | ViewID=" +
                spawnedView.ViewID);

            return true;
        }

        /// <summary>
        /// 월드, 손, 일반 인벤토리, 백팩을 모두 검사하여
        /// 현재 존재하는 NestEgg를 찾습니다.
        /// </summary>
        private static bool TryFindExistingNestEgg(
            out string existingLocation)
        {
            existingLocation =
                string.Empty;

            if (TryFindWorldNestEgg(
                    out existingLocation))
            {
                return true;
            }

            if (TryFindInventoryNestEgg(
                    out existingLocation))
            {
                return true;
            }

            return false;
        }

        /// <summary>
        /// 현재 씬에 활성화된 NestEgg 오브젝트가 있는지 검사합니다.
        /// 손에 든 NestEgg도 활성 Item이므로 여기서 발견됩니다.
        /// </summary>
        private static bool TryFindWorldNestEgg(
            out string existingLocation)
        {
            existingLocation =
                string.Empty;

            Item[] allItems =
                UnityEngine.Object
                    .FindObjectsOfType<Item>();

            if (allItems == null)
            {
                return false;
            }

            for (int i = 0;
                 i < allItems.Length;
                 i++)
            {
                Item currentItem =
                    allItems[i];

                if (currentItem == null ||
                    currentItem.gameObject == null ||
                    !currentItem.gameObject.activeInHierarchy)
                {
                    continue;
                }

                if (!currentItem.gameObject.scene.IsValid())
                {
                    continue;
                }

                if (!IsNestEggName(
                        currentItem.gameObject.name))
                {
                    continue;
                }

                existingLocation =
                    "World: " +
                    currentItem.gameObject.name +
                    " at " +
                    currentItem.transform.position;

                return true;
            }

            return false;
        }

        /// <summary>
        /// 모든 플레이어의 일반 인벤토리와 백팩 내부를 검사합니다.
        /// </summary>
        private static bool TryFindInventoryNestEgg(
            out string existingLocation)
        {
            existingLocation =
                string.Empty;

            if (Character.AllCharacters == null)
            {
                return false;
            }

            foreach (
                Character character
                in Character.AllCharacters)
            {
                if (character == null ||
                    character.player == null)
                {
                    continue;
                }

                string characterName =
                    GetCharacterName(
                        character);

                /*
                 * 일반 인벤토리 슬롯 검사
                 */
                ItemSlot[] itemSlots =
                    character.player.itemSlots;

                if (itemSlots != null)
                {
                    for (int i = 0;
                         i < itemSlots.Length;
                         i++)
                    {
                        ItemSlot itemSlot =
                            itemSlots[i];

                        if (itemSlot == null ||
                            itemSlot.prefab == null)
                        {
                            continue;
                        }

                        if (!IsNestEggName(
                                itemSlot.prefab.gameObject.name))
                        {
                            continue;
                        }

                        existingLocation =
                            "Inventory: " +
                            characterName +
                            " Slot=" +
                            itemSlot.itemSlotID;

                        return true;
                    }
                }

                /*
                 * 백팩 내부 슬롯 검사
                 */
                ItemSlot backpackSlot =
                    character.player.backpackSlot;

                if (backpackSlot == null ||
                    backpackSlot.IsEmpty() ||
                    backpackSlot.data == null)
                {
                    continue;
                }

                BackpackData backpackData;

                if (!backpackSlot.data
                        .TryGetDataEntry<BackpackData>(
                            DataEntryKey.BackpackData,
                            out backpackData))
                {
                    continue;
                }

                if (backpackData == null ||
                    backpackData.itemSlots == null)
                {
                    continue;
                }

                for (int i = 0;
                     i < backpackData.itemSlots.Length;
                     i++)
                {
                    ItemSlot backpackItemSlot =
                        backpackData.itemSlots[i];

                    if (backpackItemSlot == null ||
                        backpackItemSlot.prefab == null)
                    {
                        continue;
                    }

                    if (!IsNestEggName(
                            backpackItemSlot
                                .prefab
                                .gameObject
                                .name))
                    {
                        continue;
                    }

                    existingLocation =
                        "Backpack: " +
                        characterName +
                        " Slot=" +
                        backpackItemSlot.itemSlotID;

                    return true;
                }
            }

            return false;
        }

        private static bool IsNestEggName(
            string objectName)
        {
            return string.Equals(
                NormalizeObjectName(
                    objectName),
                TargetPrefabName,
                System.StringComparison.OrdinalIgnoreCase);
        }

        private static string NormalizeObjectName(
            string objectName)
        {
            if (string.IsNullOrEmpty(
                    objectName))
            {
                return string.Empty;
            }

            string normalized =
                objectName.Trim();

            const string cloneSuffix =
                "(Clone)";

            while (normalized.EndsWith(
                       cloneSuffix,
                       System.StringComparison.OrdinalIgnoreCase))
            {
                normalized =
                    normalized.Substring(
                        0,
                        normalized.Length -
                        cloneSuffix.Length)
                    .Trim();
            }

            return normalized;
        }

        private static string GetCharacterName(
            Character character)
        {
            if (character == null)
            {
                return "Unknown";
            }

            if (character.photonView != null &&
                character.photonView.Owner != null)
            {
                string nickname =
                    character
                        .photonView
                        .Owner
                        .NickName;

                if (!string.IsNullOrEmpty(
                        nickname))
                {
                    return nickname;
                }
            }

            return character.gameObject.name;
        }

        /// <summary>
        /// 씬 변경 시 이전 맵의 자동 복구 상태를 초기화합니다.
        /// </summary>
        private static void ResetWhenSceneChanged()
        {
            Scene activeScene =
                SceneManager.GetActiveScene();

            if (currentSceneHandle ==
                activeScene.handle)
            {
                /*
                 * EggCheckpoint에서 씬 데이터를 초기화했다면
                 * YSpawn의 카운트도 함께 초기화합니다.
                 */
                if (EggCheckpoint.BrokenEggCount <
                    handledBrokenEggCount)
                {
                    handledBrokenEggCount =
                        0;

                    automaticAttemptedBrokenEggCount =
                        0;
                }

                return;
            }

            currentSceneHandle =
                activeScene.handle;

            handledBrokenEggCount =
                0;

            automaticAttemptedBrokenEggCount =
                0;

            lastProcessedFrame =
                -1;

            nextAllowedEmergencyInputTime =
                0f;

            automaticRespawnRoutineRunning =
                false;

            Logger.LogInfo(
                LogPrefix +
                "Scene changed. " +
                "Respawn state reset." +
                " | Scene=" +
                activeScene.name);
        }
    }
}

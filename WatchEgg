using BepInEx;
using HarmonyLib;

namespace Sapphire009.WatchEgg
{
    /// <summary>
    /// WatchEgg 모드의 BepInEx 진입점입니다.
    ///
    /// Developer: Sapphire009
    /// File: WatchEgg.cs
    /// </summary>
    [BepInPlugin(
        PluginGuid,
        PluginName,
        PluginVersion)]
    public sealed class WatchEggPlugin : BaseUnityPlugin
    {
        public const string PluginGuid =
            "sapphire009.watchegg";

        public const string PluginName =
            "WatchEgg";

        /*
         * 새 DLL이 실제로 로드됐는지 확인하기 위해
         * 기존 1.0.0에서 1.0.1로 변경합니다.
         */
        public const string PluginVersion =
            "1.0.1";

        private const string BuildMarker =
            "AUTODROP_BREAKABLEEGG_DEBUG_001";

        private Harmony harmony;

        private void Awake()
        {
            Logger.LogInfo(
                "[Sapphire009] WatchEgg 1.0.1 loading...");

            Logger.LogWarning(
                "[Sapphire009] Build marker: " +
                BuildMarker);

            /*
             * 반드시 PatchAll보다 먼저 호출해야 합니다.
             *
             * AutoDrop의 HarmonyPrepare와 Prefix 로그가
             * BepInEx 콘솔에 출력될 수 있도록 Logger를 전달합니다.
             */
            AutoDrop.SetLogger(Logger);

            harmony =
                new Harmony(PluginGuid);

            harmony.PatchAll();

            Logger.LogInfo(
                "[Sapphire009] Harmony PatchAll completed.");

            Logger.LogInfo(
                "[Sapphire009] WatchEgg 1.0.1 loaded successfully.");
        }

        private void OnDestroy()
        {
            if (harmony == null)
            {
                return;
            }

            harmony.UnpatchSelf();
            harmony = null;

            Logger.LogInfo(
                "[Sapphire009] WatchEgg patches removed.");
        }
    }
}

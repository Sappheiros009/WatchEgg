using System;
using BepInEx.Logging;
using HarmonyLib;
using UnityEngine;

namespace Sapphire009.WatchEgg
{
    /// <summary>
    /// NestEgg를 들고 있는 동안 째깍째깍 소리를 재생합니다.
    ///
    /// 남은 시간별 재생 속도:
    ///
    /// 20초 초과~5초:
    /// 기본 1배속, 1초 간격
    ///
    /// 5초~2초:
    /// 2배속, 0.5초 간격
    ///
    /// 2초~0초:
    /// 2.5배속, 0.4초 간격
    ///
    /// 별도의 경고음은 사용하지 않고
    /// 기존 Tick/Tock 소리의 재생 간격만 변경합니다.
    ///
    /// Developer: Sapphire009
    /// File: TimerSound.cs
    /// </summary>
    [DisallowMultipleComponent]
    public sealed class TimerSound : MonoBehaviour
    {
        public const string DeveloperName =
            "Sapphire009";

        /// <summary>
        /// 2배속 구간이 시작되는 남은 시간입니다.
        /// </summary>
        public const float DoubleSpeedStartRemainingTime =
            5f;

        /// <summary>
        /// 2.5배속 구간이 시작되는 남은 시간입니다.
        /// </summary>
        public const float FinalSpeedStartRemainingTime =
            2f;

        /// <summary>
        /// 20초~5초 구간의 기본 째깍 소리 간격입니다.
        ///
        /// 속도 1:
        /// 1초마다 한 번 재생합니다.
        /// </summary>
        private const float NormalTickInterval =
            1f;

        /// <summary>
        /// 5초~2초 구간의 째깍 소리 간격입니다.
        ///
        /// 속도 2:
        /// 0.5초마다 한 번 재생합니다.
        /// </summary>
        private const float DoubleSpeedTickInterval =
            NormalTickInterval /
            2f;

        /// <summary>
        /// 2초~0초 구간의 째깍 소리 간격입니다.
        ///
        /// 속도 2.5:
        /// 0.4초마다 한 번 재생합니다.
        /// </summary>
        private const float FinalSpeedTickInterval =
            NormalTickInterval /
            2.5f;

        /// <summary>
        /// 평상시 소리 크기입니다.
        /// </summary>
        private const float NormalVolume =
            0.42f;

        /// <summary>
        /// 시간이 거의 끝났을 때의 최대 소리 크기입니다.
        /// </summary>
        private const float MaximumVolume =
            1f;

        private const int SampleRate =
            44100;

        private const string LogPrefix =
            "[TimerSound] ";

        private static readonly ManualLogSource Logger =
            BepInEx.Logging.Logger.CreateLogSource(
                "WatchEgg.TimerSound");

        private static AudioClip tickClip;

        private static AudioClip tockClip;

        private Item item;

        private Timer timer;

        private AudioSource audioSource;

        private bool wasHeldByLocalPlayer;

        /// <summary>
        /// 5초 이하 2배속 구간에 진입했는지 기록합니다.
        /// </summary>
        private bool doubleSpeedPhaseStarted;

        /// <summary>
        /// 2초 이하 2.5배속 구간에 진입했는지 기록합니다.
        /// </summary>
        private bool finalSpeedPhaseStarted;

        private bool playTickNext =
            true;

        /// <summary>
        /// Timer.HeldTime 기준으로 다음 소리를 재생할 시각입니다.
        /// </summary>
        private float nextTickHeldTime;

        private bool gameMixerApplied;

        private void Awake()
        {
            item =
                GetComponent<Item>();

            if (!Timer.IsNestEgg(
                    item))
            {
                enabled =
                    false;

                return;
            }

            timer =
                GetComponent<Timer>();

            if (timer == null)
            {
                timer =
                    gameObject.AddComponent<Timer>();
            }

            CreateSharedAudioClips();
            CreateAudioSource();

            Logger.LogInfo(
                LogPrefix +
                "TimerSound attached to " +
                item.gameObject.name +
                " | NormalInterval=" +
                NormalTickInterval +
                " | DoubleSpeedInterval=" +
                DoubleSpeedTickInterval +
                " | FinalSpeedInterval=" +
                FinalSpeedTickInterval);
        }

        private void Update()
        {
            if (item == null)
            {
                return;
            }

            ApplyGameAudioMixer();

            if (!IsHeldByLocalPlayer())
            {
                StopAndResetSound();
                return;
            }

            if (!wasHeldByLocalPlayer)
            {
                BeginNewHold();
            }

            if (timer == null)
            {
                timer =
                    GetComponent<Timer>();

                if (timer == null)
                {
                    return;
                }
            }

            float heldTime =
                timer.HeldTime;

            float remainingTime =
                timer.RemainingTime;

            if (remainingTime <= 0f)
            {
                return;
            }

            /*
             * 남은 시간이 5초 이하가 되는 순간
             * 2배속 구간으로 전환합니다.
             */
            if (remainingTime <=
                    DoubleSpeedStartRemainingTime &&
                !doubleSpeedPhaseStarted)
            {
                doubleSpeedPhaseStarted =
                    true;

                /*
                 * 구간 진입 시 기존 1초 대기시간이 남아 있더라도
                 * 다음 Tick을 즉시 재생할 수 있게 합니다.
                 */
                nextTickHeldTime =
                    Mathf.Min(
                        nextTickHeldTime,
                        heldTime);

                Logger.LogWarning(
                    LogPrefix +
                    "Double-speed phase started." +
                    " | RemainingTime=" +
                    remainingTime.ToString("F2") +
                    " | Speed=2.0" +
                    " | Interval=" +
                    DoubleSpeedTickInterval);
            }

            /*
             * 남은 시간이 2초 이하가 되는 순간
             * 2.5배속 구간으로 전환합니다.
             */
            if (remainingTime <=
                    FinalSpeedStartRemainingTime &&
                !finalSpeedPhaseStarted)
            {
                finalSpeedPhaseStarted =
                    true;

                /*
                 * 2.5배속 구간 진입 순간에도
                 * 다음 Tick이 즉시 반응하도록 합니다.
                 */
                nextTickHeldTime =
                    Mathf.Min(
                        nextTickHeldTime,
                        heldTime);

                Logger.LogWarning(
                    LogPrefix +
                    "Final-speed phase started." +
                    " | RemainingTime=" +
                    remainingTime.ToString("F2") +
                    " | Speed=2.5" +
                    " | Interval=" +
                    FinalSpeedTickInterval);
            }

            if (heldTime <
                nextTickHeldTime)
            {
                return;
            }

            PlayCurrentTick(
                remainingTime);

            float nextInterval =
                CalculateTickInterval(
                    remainingTime);

            nextTickHeldTime =
                heldTime +
                nextInterval;
        }

        /// <summary>
        /// 로컬 플레이어가 현재 이 NestEgg를
        /// 직접 들고 있는지 확인합니다.
        /// </summary>
        private bool IsHeldByLocalPlayer()
        {
            Character localCharacter =
                Character.localCharacter;

            if (localCharacter == null ||
                localCharacter.data == null ||
                item == null)
            {
                return false;
            }

            return
                localCharacter.IsLocal &&
                localCharacter.data.currentItem ==
                item &&
                item.itemState ==
                ItemState.Held;
        }

        /// <summary>
        /// NestEgg를 새로 들었을 때
        /// 소리 상태를 처음부터 초기화합니다.
        /// </summary>
        private void BeginNewHold()
        {
            wasHeldByLocalPlayer =
                true;

            doubleSpeedPhaseStarted =
                false;

            finalSpeedPhaseStarted =
                false;

            playTickNext =
                true;

            /*
             * 달걀을 집는 즉시 첫 번째 째깍 소리를 냅니다.
             */
            nextTickHeldTime =
                0f;

            if (audioSource != null)
            {
                audioSource.Stop();
            }

            Logger.LogInfo(
                LogPrefix +
                "NestEgg timer sound started.");
        }

        /// <summary>
        /// 현재 남은 시간에 따라 같은 Tick/Tock 소리를
        /// 계산된 크기로 재생합니다.
        /// </summary>
        private void PlayCurrentTick(
            float remainingTime)
        {
            if (audioSource == null)
            {
                return;
            }

            AudioClip selectedClip =
                playTickNext
                    ? tickClip
                    : tockClip;

            if (selectedClip == null)
            {
                return;
            }

            float volume =
                CalculateTickVolume(
                    remainingTime);

            /*
             * 음정 자체는 변경하지 않습니다.
             *
             * 소리 재생 간격만 줄여서
             * Tick/Tock 속도가 빨라지도록 합니다.
             */
            audioSource.pitch =
                1f;

            audioSource.PlayOneShot(
                selectedClip,
                volume);

            playTickNext =
                !playTickNext;
        }

        /// <summary>
        /// 남은 시간에 따라 Tick/Tock 재생 간격을 결정합니다.
        ///
        /// 5초 초과:
        /// 1초 간격, 속도 1
        ///
        /// 5초 이하~2초 초과:
        /// 0.5초 간격, 속도 2
        ///
        /// 2초 이하:
        /// 0.4초 간격, 속도 2.5
        /// </summary>
        private static float CalculateTickInterval(
            float remainingTime)
        {
            if (remainingTime <=
                FinalSpeedStartRemainingTime)
            {
                return FinalSpeedTickInterval;
            }

            if (remainingTime <=
                DoubleSpeedStartRemainingTime)
            {
                return DoubleSpeedTickInterval;
            }

            return NormalTickInterval;
        }

        /// <summary>
        /// 마지막 5초 동안 소리 크기를
        /// 0.42에서 1.0까지 점점 증가시킵니다.
        ///
        /// 기존 볼륨 증가 기능은 그대로 유지합니다.
        /// </summary>
        private static float CalculateTickVolume(
            float remainingTime)
        {
            if (remainingTime >
                DoubleSpeedStartRemainingTime)
            {
                return NormalVolume;
            }

            float progress =
                1f -
                Mathf.Clamp01(
                    remainingTime /
                    DoubleSpeedStartRemainingTime);

            float volumeProgress =
                Mathf.Pow(
                    progress,
                    1.35f);

            return Mathf.Lerp(
                NormalVolume,
                MaximumVolume,
                volumeProgress);
        }

        /// <summary>
        /// 달걀을 놓거나 떨어뜨리면
        /// 현재 소리와 속도 상태를 초기화합니다.
        /// </summary>
        private void StopAndResetSound()
        {
            if (!wasHeldByLocalPlayer)
            {
                return;
            }

            wasHeldByLocalPlayer =
                false;

            doubleSpeedPhaseStarted =
                false;

            finalSpeedPhaseStarted =
                false;

            playTickNext =
                true;

            nextTickHeldTime =
                0f;

            if (audioSource != null)
            {
                audioSource.Stop();
            }

            Logger.LogInfo(
                LogPrefix +
                "NestEgg timer sound stopped.");
        }

        private void OnDisable()
        {
            StopAndResetSound();
        }

        private void OnDestroy()
        {
            if (audioSource != null)
            {
                audioSource.Stop();
            }
        }

        /// <summary>
        /// 같은 Tick/Tock 소리를 연속 재생할
        /// AudioSource 하나를 생성합니다.
        /// </summary>
        private void CreateAudioSource()
        {
            audioSource =
                gameObject.AddComponent<AudioSource>();

            audioSource.playOnAwake =
                false;

            audioSource.loop =
                false;

            /*
             * 달걀을 들고 있는 로컬 플레이어에게만 재생하므로
             * 거리 감쇠가 없는 2D 사운드로 설정합니다.
             */
            audioSource.spatialBlend =
                0f;

            audioSource.dopplerLevel =
                0f;

            audioSource.volume =
                1f;

            audioSource.pitch =
                1f;

            audioSource.priority =
                32;

            audioSource.bypassEffects =
                false;

            audioSource.bypassListenerEffects =
                false;

            audioSource.bypassReverbZones =
                true;
        }

        /// <summary>
        /// PEAK의 효과음 믹서가 준비되면 연결합니다.
        /// </summary>
        private void ApplyGameAudioMixer()
        {
            if (gameMixerApplied ||
                audioSource == null ||
                SFX_Player.instance == null)
            {
                return;
            }

            audioSource.outputAudioMixerGroup =
                SFX_Player.instance.defaultMixerGroup;

            gameMixerApplied =
                true;

            Logger.LogInfo(
                LogPrefix +
                "PEAK SFX mixer applied.");
        }

        /// <summary>
        /// Tick과 Tock 클립을 한 번만 생성합니다.
        /// </summary>
        private static void CreateSharedAudioClips()
        {
            if (tickClip == null)
            {
                tickClip =
                    CreateClockClickClip(
                        "WatchEgg_NestEgg_TimerTick",
                        1750f,
                        0.065f,
                        0.78f);
            }

            if (tockClip == null)
            {
                tockClip =
                    CreateClockClickClip(
                        "WatchEgg_NestEgg_TimerTock",
                        1050f,
                        0.085f,
                        0.72f);
            }
        }

        /// <summary>
        /// 짧은 시계 째깍 소리를 생성합니다.
        /// </summary>
        private static AudioClip CreateClockClickClip(
            string clipName,
            float frequency,
            float duration,
            float strength)
        {
            int sampleCount =
                Mathf.Max(
                    1,
                    Mathf.CeilToInt(
                        SampleRate *
                        duration));

            float[] samples =
                new float[sampleCount];

            uint noiseState =
                2463534242u;

            for (int i = 0;
                 i < sampleCount;
                 i++)
            {
                float time =
                    (float)i /
                    SampleRate;

                float normalizedTime =
                    time /
                    duration;

                float attack =
                    Mathf.Clamp01(
                        time /
                        0.0025f);

                float decay =
                    Mathf.Exp(
                        -normalizedTime *
                        8.5f);

                float envelope =
                    attack *
                    decay;

                float primaryTone =
                    Mathf.Sin(
                        2f *
                        Mathf.PI *
                        frequency *
                        time);

                float secondaryTone =
                    Mathf.Sin(
                        2f *
                        Mathf.PI *
                        frequency *
                        2.17f *
                        time);

                noiseState =
                    noiseState *
                    1664525u +
                    1013904223u;

                float noise =
                    ((noiseState >> 8) /
                     16777215f) *
                    2f -
                    1f;

                float value =
                    primaryTone *
                    0.58f +
                    secondaryTone *
                    0.20f +
                    noise *
                    0.22f;

                samples[i] =
                    Mathf.Clamp(
                        value *
                        envelope *
                        strength,
                        -1f,
                        1f);
            }

            return CreateAudioClipFromSamples(
                clipName,
                samples);
        }

        /// <summary>
        /// PCMReaderCallback을 사용해
        /// 오디오 샘플을 AudioClip으로 생성합니다.
        /// </summary>
        private static AudioClip CreateAudioClipFromSamples(
            string clipName,
            float[] sourceSamples)
        {
            if (sourceSamples == null ||
                sourceSamples.Length == 0)
            {
                return null;
            }

            AudioClip audioClip =
                AudioClip.Create(
                    clipName,
                    sourceSamples.Length,
                    1,
                    SampleRate,
                    false,
                    delegate (float[] outputSamples)
                    {
                        if (outputSamples == null)
                        {
                            return;
                        }

                        int copyLength =
                            Mathf.Min(
                                outputSamples.Length,
                                sourceSamples.Length);

                        Array.Copy(
                            sourceSamples,
                            0,
                            outputSamples,
                            0,
                            copyLength);

                        for (int i = copyLength;
                             i < outputSamples.Length;
                             i++)
                        {
                            outputSamples[i] =
                                0f;
                        }
                    });

            if (audioClip != null)
            {
                audioClip.hideFlags =
                    HideFlags.HideAndDontSave;
            }

            return audioClip;
        }

        /// <summary>
        /// 모든 NestEgg 인스턴스에 Timer와 TimerSound를 부착합니다.
        /// </summary>
        [HarmonyPatch(
            typeof(Item),
            "Awake")]
        private static class ItemAwakePatch
        {
            [HarmonyPostfix]
            private static void Postfix(
                Item __instance)
            {
                if (!Timer.IsNestEgg(
                        __instance))
                {
                    return;
                }

                if (__instance.GetComponent<Timer>() ==
                    null)
                {
                    __instance.gameObject
                        .AddComponent<Timer>();
                }

                if (__instance.GetComponent<TimerSound>() !=
                    null)
                {
                    return;
                }

                __instance.gameObject
                    .AddComponent<TimerSound>();
            }
        }
    }
}

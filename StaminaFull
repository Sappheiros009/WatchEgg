using BepInEx;
using BepInEx.Logging;
using HarmonyLib;
using Peak.Afflictions;
using System;
using UnityEngine;
using UnityEngine.SceneManagement;

[BepInPlugin(PluginGUID, PluginName, PluginVersion)]
public sealed class StaminaFull : BaseUnityPlugin
{
    public const string PluginGUID =
        "Sapphire009.StaminaFull";

    public const string PluginName =
        "StaminaFull";

    public const string PluginVersion =
        "1.0.1";

    private const string BuildMarker =
        "StatusProtection-NormalStamina-R3";

    private const int MaximumLogCount =
        50;

    internal static ManualLogSource ModLogger;

    private static int blockedStatusLogCount;
    private static int blockedAfflictionLogCount;
    private static int blockedThornLogCount;

    private Harmony harmony;

    private void Awake()
    {
        ModLogger =
            Logger;

        harmony =
            new Harmony(PluginGUID);

        harmony.PatchAll();

        Logger.LogInfo(
            $"{PluginName} {PluginVersion} loaded. " +
            $"Build: {BuildMarker}. " +
            "Complete status protection is enabled outside Airport. " +
            "Original stamina consumption remains enabled.");
    }

    private void OnDestroy()
    {
        blockedStatusLogCount =
            0;

        blockedAfflictionLogCount =
            0;

        blockedThornLogCount =
            0;

        if (harmony != null)
        {
            harmony.UnpatchSelf();

            harmony =
                null;
        }

        ModLogger =
            null;
    }

    internal static bool IsAirportScene()
    {
        string sceneName =
            SceneManager.GetActiveScene().name;

        if (string.IsNullOrEmpty(
                sceneName))
        {
            return false;
        }

        return sceneName.IndexOf(
                   "Airport",
                   StringComparison.OrdinalIgnoreCase) >=
               0;
    }

    internal static bool CanApplyProtection(
        Character character)
    {
        if (character == null ||
            !character.IsLocal ||
            character.data == null ||
            character.refs == null ||
            character.refs.afflictions == null)
        {
            return false;
        }

        if (IsAirportScene())
        {
            return false;
        }

        return true;
    }

    internal static bool CanApplyProtection(
        CharacterAfflictions afflictions)
    {
        if (afflictions == null)
        {
            return false;
        }

        return CanApplyProtection(
            afflictions.character);
    }

    /*
     * 이미 적용돼 있던 부상, 허기, 추위, 독 등의 상태와
     * 지속형 Affliction 및 몸에 박힌 가시를 제거합니다.
     *
     * 스태미나 값은 수정하지 않습니다.
     */
    internal static void ClearAllNegativeStates(
        Character character)
    {
        if (!CanApplyProtection(
                character))
        {
            return;
        }

        CharacterAfflictions afflictions =
            character.refs.afflictions;

        bool statusChanged =
            false;

        int statusCount =
            CharacterAfflictions.NumStatusTypes;

        for (int i = 0;
             i < statusCount;
             i++)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                (CharacterAfflictions.STATUSTYPE)i;

            if (afflictions.GetCurrentStatus(
                    statusType) <=
                0f)
            {
                continue;
            }

            /*
             * 현재 적용돼 있는 상태 수치를 0으로 제거합니다.
             */
            afflictions.SetStatus(
                statusType,
                0f,
                false);

            statusChanged =
                true;
        }

        /*
         * Web 상태 수치가 0이어도 내부 플래그가 남는 경우를
         * 방지하기 위해 함께 해제합니다.
         */
        if (afflictions.isWebbed)
        {
            afflictions.SetStatus(
                CharacterAfflictions.STATUSTYPE.Web,
                0f,
                false);

            afflictions.isWebbed =
                false;

            statusChanged =
                true;
        }

        if (statusChanged)
        {
            afflictions.PushStatuses(
                null);
        }

        /*
         * 독 지속 피해, 좀비 감염, 졸음, 저주 등의
         * 지속형 Affliction을 제거합니다.
         */
        if (afflictions.afflictionList != null &&
            afflictions.afflictionList.Count >
            0)
        {
            afflictions.ClearAllAfflictions();
        }

        /*
         * 이미 몸에 박혀 있는 가시도 제거합니다.
         */
        if (afflictions.physicalThorns != null)
        {
            for (int i =
                     afflictions.physicalThorns.Count -
                     1;
                 i >= 0;
                 i--)
            {
                ThornOnMe thorn =
                    afflictions.physicalThorns[i];

                if (thorn == null ||
                    !thorn.stuckIn)
                {
                    continue;
                }

                afflictions.RemoveThorn(
                    thorn);
            }
        }
    }

    /*
     * Injury, Hunger, Cold, Poison, Crab, Curse,
     * Drowsy, Weight, Hot, Thorns, Spores, Web 등
     * 양수 상태가 새로 추가되는 것을 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddStatus),
        new Type[]
        {
            typeof(CharacterAfflictions.STATUSTYPE),
            typeof(float),
            typeof(bool),
            typeof(bool),
            typeof(bool)
        })]
    private static class CharacterAfflictionsAddStatusPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            CharacterAfflictions.STATUSTYPE __0,
            float __1,
            bool __2,
            bool __3,
            bool __4,
            ref bool __result)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                __0;

            float amount =
                __1;

            if (amount <= 0f ||
                !CanApplyProtection(
                    __instance))
            {
                return true;
            }

            __result =
                false;

            LogBlockedStatus(
                statusType,
                amount,
                "AddStatus");

            return false;
        }
    }

    /*
     * AdjustStatus를 통해 들어오는 양수 상태 변화도 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AdjustStatus),
        new Type[]
        {
            typeof(CharacterAfflictions.STATUSTYPE),
            typeof(float),
            typeof(bool)
        })]
    private static class CharacterAfflictionsAdjustStatusPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            CharacterAfflictions.STATUSTYPE __0,
            float __1,
            bool __2)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                __0;

            float amount =
                __1;

            if (amount <= 0f ||
                !CanApplyProtection(
                    __instance))
            {
                return true;
            }

            LogBlockedStatus(
                statusType,
                amount,
                "AdjustStatus");

            return false;
        }
    }

    /*
     * SetStatus가 현재보다 높은 값으로 상태를 직접 설정하는
     * 경우를 차단합니다.
     *
     * 현재보다 낮게 만들거나 0으로 제거하는 처리는 허용합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.SetStatus),
        new Type[]
        {
            typeof(CharacterAfflictions.STATUSTYPE),
            typeof(float),
            typeof(bool)
        })]
    private static class CharacterAfflictionsSetStatusPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            CharacterAfflictions.STATUSTYPE __0,
            float __1,
            bool __2)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                __0;

            float requestedAmount =
                __1;

            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            float currentAmount =
                __instance.GetCurrentStatus(
                    statusType);

            if (requestedAmount <=
                currentAmount)
            {
                return true;
            }

            LogBlockedStatus(
                statusType,
                requestedAmount -
                currentAmount,
                "SetStatus");

            return false;
        }
    }

    /*
     * PoisonOverTime, ZombieBite, Drowsy 등
     * 지속형 Affliction 추가를 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddAffliction),
        new Type[]
        {
            typeof(Affliction),
            typeof(bool)
        })]
    private static class CharacterAfflictionsAddAfflictionPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            Affliction __0,
            bool __1)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            if (blockedAfflictionLogCount <
                MaximumLogCount)
            {
                blockedAfflictionLogCount++;

                string afflictionName =
                    __0 != null
                        ? __0.GetType().Name
                        : "null";

                ModLogger?.LogInfo(
                    $"[StaminaFull] Affliction blocked " +
                    $"({blockedAfflictionLogCount}/" +
                    $"{MaximumLogCount}). " +
                    $"Affliction={afflictionName}, " +
                    $"Scene=" +
                    $"{SceneManager.GetActiveScene().name}");
            }

            return false;
        }
    }

    /*
     * 위치 기반 가시 추가를 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddThorn),
        new Type[]
        {
            typeof(Vector3)
        })]
    private static class CharacterAfflictionsAddThornPositionPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            Vector3 __0)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            LogBlockedThorn();

            return false;
        }
    }

    /*
     * 인덱스 기반 가시 추가를 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddThorn),
        new Type[]
        {
            typeof(ushort)
        })]
    private static class CharacterAfflictionsAddThornIndexPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            ushort __0)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            LogBlockedThorn();

            return false;
        }
    }

    /*
     * RPC를 통해 가시가 직접 활성화되는 경우도 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.RPC_EnableThorn),
        new Type[]
        {
            typeof(int)
        })]
    private static class CharacterAfflictionsEnableThornPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            int __0)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            LogBlockedThorn();

            return false;
        }
    }

    /*
     * 다른 코드나 네트워크 동기화로 이미 상태가 적용됐더라도
     * 다음 물리 프레임에 제거합니다.
     *
     * 기존 버전과 달리 여기서 스태미나를 복구하지 않습니다.
     */
    [HarmonyPatch(
        typeof(Character),
        "FixedUpdate")]
    private static class CharacterFixedUpdatePatch
    {
        [HarmonyPostfix]
        private static void Postfix(
            Character __instance)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return;
            }

            ClearAllNegativeStates(
                __instance);
        }
    }

    private static void LogBlockedStatus(
        CharacterAfflictions.STATUSTYPE statusType,
        float amount,
        string source)
    {
        if (blockedStatusLogCount >=
            MaximumLogCount)
        {
            return;
        }

        blockedStatusLogCount++;

        ModLogger?.LogInfo(
            $"[StaminaFull] Status blocked " +
            $"({blockedStatusLogCount}/" +
            $"{MaximumLogCount}). " +
            $"Status={statusType}, " +
            $"Amount={amount:0.0000}, " +
            $"Source={source}, " +
            $"Scene=" +
            $"{SceneManager.GetActiveScene().name}");
    }

    private static void LogBlockedThorn()
    {
        if (blockedThornLogCount >=
            MaximumLogCount)
        {
            return;
        }

        blockedThornLogCount++;

        ModLogger?.LogInfo(
            $"[StaminaFull] Thorn blocked " +
            $"({blockedThornLogCount}/" +
            $"{MaximumLogCount}). " +
            $"Scene=" +
            $"{SceneManager.GetActiveScene().name}");
    }
}

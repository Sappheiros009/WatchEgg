using BepInEx;
using BepInEx.Logging;
using HarmonyLib;
using Peak.Afflictions;
using System;
using System.Collections.Generic;
using UnityEngine;
using UnityEngine.SceneManagement;

[BepInPlugin(PluginGUID, PluginName, PluginVersion)]
public sealed class StaminaFull : BaseUnityPlugin
{
    public const string PluginGUID = "Sapphire009.StaminaFull";
    public const string PluginName = "StaminaFull";
    public const string PluginVersion = "1.0.0";

    private const string BuildMarker =
        "InfiniteStamina-AllStatusBlock-R2";

    private const int MaximumLogCount = 50;

    internal static ManualLogSource ModLogger;

    /*
     * 보너스 스태미나가 직접 수정되는 경우에도
     * 이전보다 감소하지 않도록 캐릭터별 최고값을 저장합니다.
     */
    private static readonly Dictionary<int, float>
        PreservedExtraStamina =
            new Dictionary<int, float>();

    private static int blockedStatusLogCount;
    private static int blockedAfflictionLogCount;
    private static int blockedThornLogCount;

    private Harmony harmony;

    private void Awake()
    {
        ModLogger = Logger;

        harmony = new Harmony(PluginGUID);
        harmony.PatchAll();

        Logger.LogInfo(
            $"{PluginName} {PluginVersion} loaded. " +
            $"Build: {BuildMarker}. " +
            "Infinite stamina and complete status protection " +
            "are enabled outside Airport.");
    }

    private void OnDestroy()
    {
        PreservedExtraStamina.Clear();

        blockedStatusLogCount = 0;
        blockedAfflictionLogCount = 0;
        blockedThornLogCount = 0;

        if (harmony != null)
        {
            harmony.UnpatchSelf();
            harmony = null;
        }

        ModLogger = null;
    }

    internal static bool IsAirportScene()
    {
        string sceneName =
            SceneManager.GetActiveScene().name;

        if (string.IsNullOrEmpty(sceneName))
        {
            return false;
        }

        return sceneName.IndexOf(
                   "Airport",
                   StringComparison.OrdinalIgnoreCase) >= 0;
    }

    internal static bool CanApplyProtection(
        Character character)
    {
        if (character == null ||
            !character.IsLocal ||
            character.data == null ||
            character.refs == null ||
            character.refs.afflictions == null)
        {
            return false;
        }

        if (IsAirportScene())
        {
            return false;
        }

        return true;
    }

    internal static bool CanApplyProtection(
        CharacterAfflictions afflictions)
    {
        if (afflictions == null)
        {
            return false;
        }

        return CanApplyProtection(
            afflictions.character);
    }

    /*
     * 일반 스태미나를 현재 최대치로 복구하고,
     * 보너스 스태미나는 이전 값보다 감소하지 않게 합니다.
     */
    internal static void FillAndPreserveStamina(
        Character character)
    {
        if (!CanApplyProtection(character))
        {
            if (character != null)
            {
                PreservedExtraStamina.Remove(
                    character.GetInstanceID());
            }

            return;
        }

        float maximumStamina =
            character.GetMaxStamina();

        /*
         * 모든 상태를 0으로 유지하므로 일반 최대치는
         * 정상적으로 1이 됩니다.
         */
        maximumStamina =
            Mathf.Max(
                maximumStamina,
                1f);

        bool staminaChanged =
            false;

        if (Mathf.Abs(
                character.data.currentStamina -
                maximumStamina) >
            0.0001f)
        {
            character.data.currentStamina =
                maximumStamina;

            staminaChanged =
                true;
        }

        int characterId =
            character.GetInstanceID();

        float preservedExtra;

        if (!PreservedExtraStamina.TryGetValue(
                characterId,
                out preservedExtra))
        {
            preservedExtra =
                character.data.extraStamina;

            PreservedExtraStamina.Add(
                characterId,
                preservedExtra);
        }
        else
        {
            /*
             * 아이템 등으로 보너스 스태미나가 증가하면
             * 새로운 최고값으로 저장합니다.
             */
            if (character.data.extraStamina >
                preservedExtra)
            {
                preservedExtra =
                    character.data.extraStamina;

                PreservedExtraStamina[
                    characterId] =
                        preservedExtra;
            }
            /*
             * 보너스 스태미나가 감소했다면
             * 저장된 값으로 되돌립니다.
             */
            else if (character.data.extraStamina <
                     preservedExtra)
            {
                character.data.extraStamina =
                    preservedExtra;

                staminaChanged =
                    true;
            }
        }

        if (staminaChanged &&
            GUIManager.instance != null &&
            GUIManager.instance.bar != null)
        {
            GUIManager.instance.bar.ChangeBar();
        }
    }

    /*
     * 이미 적용돼 있던 부상, 허기, 독 등의 상태와
     * 지속형 Affliction 및 가시를 제거합니다.
     */
    internal static void ClearAllNegativeStates(
        Character character)
    {
        if (!CanApplyProtection(character))
        {
            return;
        }

        CharacterAfflictions afflictions =
            character.refs.afflictions;

        bool statusChanged =
            false;

        int statusCount =
            CharacterAfflictions.NumStatusTypes;

        for (int i = 0;
             i < statusCount;
             i++)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                (CharacterAfflictions.STATUSTYPE)i;

            if (afflictions.GetCurrentStatus(
                    statusType) <= 0f)
            {
                continue;
            }

            /*
             * SetStatus의 0 감소는 허용되므로
             * 현재 적용된 모든 상태를 제거합니다.
             */
            afflictions.SetStatus(
                statusType,
                0f,
                false);

            statusChanged =
                true;
        }

        /*
         * Web 상태값이 이미 0이어도 내부 플래그가 남아 있으면
         * 거미줄 판정이 계속될 수 있으므로 함께 해제합니다.
         */
        if (afflictions.isWebbed)
        {
            afflictions.SetStatus(
                CharacterAfflictions.STATUSTYPE.Web,
                0f,
                false);

            afflictions.isWebbed =
                false;

            statusChanged =
                true;
        }

        if (statusChanged)
        {
            afflictions.PushStatuses(
                null);
        }

        /*
         * 독 지속 피해, 좀비 감염, 졸음, 저주,
         * 스태미나 변화 등의 지속형 Affliction도 제거합니다.
         */
        if (afflictions.afflictionList != null &&
            afflictions.afflictionList.Count > 0)
        {
            afflictions.ClearAllAfflictions();
        }

        /*
         * 이미 몸에 박힌 가시도 제거합니다.
         */
        if (afflictions.physicalThorns != null)
        {
            for (int i =
                     afflictions.physicalThorns.Count - 1;
                 i >= 0;
                 i--)
            {
                ThornOnMe thorn =
                    afflictions.physicalThorns[i];

                if (thorn == null ||
                    !thorn.stuckIn)
                {
                    continue;
                }

                afflictions.RemoveThorn(
                    thorn);
            }
        }
    }

    /*
     * 등반, 달리기, 물건 들기 등에서 호출되는
     * PEAK 원본 스태미나 소비를 성공 처리하면서
     * 실제 수치는 차감하지 않습니다.
     */
    [HarmonyPatch(
        typeof(Character),
        "UseStamina",
        new Type[]
        {
            typeof(float),
            typeof(bool)
        })]
    private static class CharacterUseStaminaPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            Character __instance,
            float __0,
            bool __1,
            ref bool __result)
        {
            float usage =
                __0;

            if (usage <= 0f)
            {
                return true;
            }

            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            FillAndPreserveStamina(
                __instance);

            /*
             * 스태미나를 사용했다는 시간 기록은 유지하지만
             * currentStamina와 extraStamina는 감소시키지 않습니다.
             */
            __instance.data.sinceUseStamina =
                0f;

            __result =
                true;

            return false;
        }
    }

    /*
     * AddStamina에 음수가 들어와 직접 스태미나를
     * 감소시키는 경로도 차단합니다.
     */
    [HarmonyPatch(
        typeof(Character),
        nameof(Character.AddStamina),
        new Type[]
        {
            typeof(float)
        })]
    private static class CharacterAddStaminaPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            Character __instance,
            float __0)
        {
            float amount =
                __0;

            if (amount >= 0f)
            {
                return true;
            }

            return !CanApplyProtection(
                __instance);
        }
    }

    /*
     * 보너스 스태미나를 낮은 값으로 직접 설정하는 경로를
     * 즉시 차단합니다.
     */
    [HarmonyPatch(
        typeof(Character),
        nameof(Character.SetExtraStamina),
        new Type[]
        {
            typeof(float)
        })]
    private static class CharacterSetExtraStaminaPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            Character __instance,
            float __0)
        {
            float requestedAmount =
                __0;

            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            if (requestedAmount >=
                __instance.data.extraStamina)
            {
                return true;
            }

            return false;
        }
    }

    /*
     * AddExtraStamina에 음수가 들어오는 경우도 차단합니다.
     */
    [HarmonyPatch(
        typeof(Character),
        nameof(Character.AddExtraStamina),
        new Type[]
        {
            typeof(float)
        })]
    private static class CharacterAddExtraStaminaPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            Character __instance,
            float __0)
        {
            float amount =
                __0;

            if (amount >= 0f)
            {
                return true;
            }

            return !CanApplyProtection(
                __instance);
        }
    }

    /*
     * Injury, Hunger, Cold, Poison, Crab, Curse,
     * Drowsy, Weight, Hot, Thorns, Spores, Web 등
     * 모든 양수 상태 추가를 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddStatus),
        new Type[]
        {
            typeof(CharacterAfflictions.STATUSTYPE),
            typeof(float),
            typeof(bool),
            typeof(bool),
            typeof(bool)
        })]
    private static class CharacterAfflictionsAddStatusPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            CharacterAfflictions.STATUSTYPE __0,
            float __1,
            bool __2,
            bool __3,
            bool __4,
            ref bool __result)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                __0;

            float amount =
                __1;

            if (amount <= 0f ||
                !CanApplyProtection(__instance))
            {
                return true;
            }

            __result =
                false;

            LogBlockedStatus(
                statusType,
                amount,
                "AddStatus");

            return false;
        }
    }

    /*
     * AdjustStatus를 통해 들어오는 양수 상태 변화도 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AdjustStatus),
        new Type[]
        {
            typeof(CharacterAfflictions.STATUSTYPE),
            typeof(float),
            typeof(bool)
        })]
    private static class CharacterAfflictionsAdjustStatusPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            CharacterAfflictions.STATUSTYPE __0,
            float __1,
            bool __2)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                __0;

            float amount =
                __1;

            if (amount <= 0f ||
                !CanApplyProtection(__instance))
            {
                return true;
            }

            LogBlockedStatus(
                statusType,
                amount,
                "AdjustStatus");

            return false;
        }
    }

    /*
     * SetStatus가 현재보다 높은 수치로 상태를 직접 지정하는
     * 경로도 차단합니다.
     *
     * 상태를 0으로 낮추는 동작은 허용합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.SetStatus),
        new Type[]
        {
            typeof(CharacterAfflictions.STATUSTYPE),
            typeof(float),
            typeof(bool)
        })]
    private static class CharacterAfflictionsSetStatusPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            CharacterAfflictions.STATUSTYPE __0,
            float __1,
            bool __2)
        {
            CharacterAfflictions.STATUSTYPE statusType =
                __0;

            float requestedAmount =
                __1;

            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            float currentAmount =
                __instance.GetCurrentStatus(
                    statusType);

            /*
             * 현재보다 낮은 수치나 0으로 치료하는 동작은 허용합니다.
             */
            if (requestedAmount <=
                currentAmount)
            {
                return true;
            }

            LogBlockedStatus(
                statusType,
                requestedAmount - currentAmount,
                "SetStatus");

            return false;
        }
    }

    /*
     * PoisonOverTime, ZombieBite, Drowsy 등
     * 지속형 Affliction 자체의 추가를 차단합니다.
     *
     * 모든 Affliction을 막으므로 유익한 시간제 버프도
     * 이 모드가 활성화된 동안에는 추가되지 않습니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddAffliction),
        new Type[]
        {
            typeof(Affliction),
            typeof(bool)
        })]
    private static class CharacterAfflictionsAddAfflictionPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            Affliction __0,
            bool __1)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            if (blockedAfflictionLogCount <
                MaximumLogCount)
            {
                blockedAfflictionLogCount++;

                string afflictionName =
                    __0 != null
                        ? __0.GetType().Name
                        : "null";

                ModLogger?.LogInfo(
                    $"[StaminaFull] Affliction blocked " +
                    $"({blockedAfflictionLogCount}/" +
                    $"{MaximumLogCount}). " +
                    $"Affliction={afflictionName}, " +
                    $"Scene=" +
                    $"{SceneManager.GetActiveScene().name}");
            }

            return false;
        }
    }

    /*
     * 위치 기반 가시 추가를 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddThorn),
        new Type[]
        {
            typeof(Vector3)
        })]
    private static class CharacterAfflictionsAddThornPositionPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            Vector3 __0)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            LogBlockedThorn();

            return false;
        }
    }

    /*
     * 인덱스 기반 가시 추가도 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.AddThorn),
        new Type[]
        {
            typeof(ushort)
        })]
    private static class CharacterAfflictionsAddThornIndexPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            ushort __0)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            LogBlockedThorn();

            return false;
        }
    }

    /*
     * RPC를 통해 가시 오브젝트가 직접 활성화되는 경우도
     * 로컬 캐릭터에서는 차단합니다.
     */
    [HarmonyPatch(
        typeof(CharacterAfflictions),
        nameof(CharacterAfflictions.RPC_EnableThorn),
        new Type[]
        {
            typeof(int)
        })]
    private static class CharacterAfflictionsEnableThornPatch
    {
        [HarmonyPrefix]
        private static bool Prefix(
            CharacterAfflictions __instance,
            int __0)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                return true;
            }

            LogBlockedThorn();

            return false;
        }
    }

    /*
     * 다른 코드나 네트워크 동기화가 값을 직접 변경했더라도
     * 다음 물리 프레임에 다시 완전한 상태로 복구합니다.
     */
    [HarmonyPatch(
        typeof(Character),
        "FixedUpdate")]
    private static class CharacterFixedUpdatePatch
    {
        [HarmonyPostfix]
        private static void Postfix(
            Character __instance)
        {
            if (!CanApplyProtection(
                    __instance))
            {
                if (__instance != null)
                {
                    PreservedExtraStamina.Remove(
                        __instance.GetInstanceID());
                }

                return;
            }

            ClearAllNegativeStates(
                __instance);

            FillAndPreserveStamina(
                __instance);
        }
    }

    private static void LogBlockedStatus(
        CharacterAfflictions.STATUSTYPE statusType,
        float amount,
        string source)
    {
        if (blockedStatusLogCount >=
            MaximumLogCount)
        {
            return;
        }

        blockedStatusLogCount++;

        ModLogger?.LogInfo(
            $"[StaminaFull] Status blocked " +
            $"({blockedStatusLogCount}/{MaximumLogCount}). " +
            $"Status={statusType}, " +
            $"Amount={amount:0.0000}, " +
            $"Source={source}, " +
            $"Scene={SceneManager.GetActiveScene().name}");
    }

    private static void LogBlockedThorn()
    {
        if (blockedThornLogCount >=
            MaximumLogCount)
        {
            return;
        }

        blockedThornLogCount++;

        ModLogger?.LogInfo(
            $"[StaminaFull] Thorn blocked " +
            $"({blockedThornLogCount}/{MaximumLogCount}). " +
            $"Scene={SceneManager.GetActiveScene().name}");
    }
}

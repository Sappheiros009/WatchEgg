using System;
using HarmonyLib;
using UnityEngine;

namespace Sapphire009.WatchEgg
{
    /// <summary>
    /// NestEgg가 로컬 플레이어 또는 다른 플레이어의 몸에 충돌했을 때
    /// 달걀이 깨지지 않도록 합니다.
    /// </summary>
    [HarmonyPatch(typeof(Breakable), "OnCollisionEnter")]
    public static class NoBody
    {
        private const string TargetPrefabName = "NestEgg";

        /// <summary>
        /// true  = PEAK 원본 충돌 처리 실행
        /// false = 플레이어 몸 충돌이므로 원본 파손 처리 생략
        /// </summary>
        [HarmonyPrefix]
        private static bool Prefix(
            Breakable __instance,
            Collision collision)
        {
            if (__instance == null || collision == null)
            {
                return true;
            }

            Item item = __instance.GetComponent<Item>();

            if (item == null || !IsNestEgg(item.gameObject.name))
            {
                return true;
            }

            Collider collidedCollider = collision.collider;

            if (collidedCollider == null)
            {
                return true;
            }

            Bodypart collidedBodypart =
                collidedCollider.GetComponentInParent<Bodypart>();

            if (collidedBodypart != null)
            {
                return false;
            }

            return true;
        }

        private static bool IsNestEgg(string objectName)
        {
            if (string.IsNullOrWhiteSpace(objectName))
            {
                return false;
            }

            string normalizedName = objectName.Trim();
            const string cloneSuffix = "(Clone)";

            while (normalizedName.EndsWith(
                cloneSuffix,
                StringComparison.OrdinalIgnoreCase))
            {
                normalizedName = normalizedName
                    .Substring(
                        0,
                        normalizedName.Length - cloneSuffix.Length)
                    .Trim();
            }

            return string.Equals(
                normalizedName,
                TargetPrefabName,
                StringComparison.OrdinalIgnoreCase);
        }
    }
}

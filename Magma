using HarmonyLib;
using System;
using UnityEngine;

namespace Sapphire009.WatchEgg
{
    /// <summary>
    /// PEAK 원본 용암 데미지를 복구합니다.
    ///
    /// 원본 Lava.HitPlayer는 플레이어에게
    /// Injury 0.25와 Hot 0.25를 적용합니다.
    ///
    /// WatchEgg 프로젝트의 StaminaFull은 일반 상태이상을 차단하고
    /// 이미 들어온 상태도 Character.FixedUpdate에서 제거하므로,
    /// 용암에 직접 닿은 로컬 플레이어에 한해서만 짧은 시간 동안
    /// StaminaFull 보호를 해제하여 원본 용암 데미지가 정상 작동하게 합니다.
    ///
    /// 즉사 처리, 추가 데미지, 직접 상태값 변경은 하지 않습니다.
    ///
    /// Developer: Sapphire009
    /// File: Magma.cs
    /// </summary>
    internal static class Magma
    {
        internal const string DeveloperName = "Sapphire009";

        /*
         * PEAK 원본 Lava.IHoldPlayer는 HitPlayer 재호출을 약 1초 동안 막습니다.
         * 다음 원본 타격이 들어오기 전까지 StaminaFull이 방금 받은
         * Injury와 Hot을 지우지 않도록 약간의 여유를 둡니다.
         */
        private const float ProtectionBypassDuration = 1.25f;

        private static Character activeLavaCharacter;
        private static float protectionBypassUntil;

        /// <summary>
        /// PEAK 원본 Lava.HitPlayer가 호출되기 직전에
        /// 현재 로컬 플레이어를 용암 데미지 허용 대상으로 등록합니다.
        /// </summary>
        internal static void RegisterOriginalLavaHit(Character character)
        {
            if (character == null ||
                !character.IsLocal ||
                character.data == null ||
                character.data.dead)
            {
                return;
            }

            activeLavaCharacter = character;
            protectionBypassUntil =
                Time.time + ProtectionBypassDuration;
        }

        /// <summary>
        /// 현재 캐릭터가 최근 PEAK 원본 용암 타격을 받은
        /// 로컬 플레이어인지 검사합니다.
        /// </summary>
        internal static bool ShouldBypassStaminaFull(
            Character character)
        {
            if (character == null ||
                activeLavaCharacter == null ||
                character != activeLavaCharacter)
            {
                return false;
            }

            if (!character.IsLocal ||
                character.data == null ||
                character.data.dead)
            {
                ClearActiveLavaCharacter();
                return false;
            }

            if (Time.time > protectionBypassUntil)
            {
                ClearActiveLavaCharacter();
                return false;
            }

            return true;
        }

        private static void ClearActiveLavaCharacter()
        {
            activeLavaCharacter = null;
            protectionBypassUntil = 0f;
        }
    }

    /// <summary>
    /// 원본 Lava.HitPlayer는 그대로 실행합니다.
    /// Prefix에서는 StaminaFull 보호 해제 시간만 등록합니다.
    /// </summary>
    [HarmonyPatch(
        typeof(Lava),
        "HitPlayer",
        new Type[]
        {
            typeof(Character)
        })]
    internal static class MagmaLavaHitPlayerPatch
    {
        [HarmonyPrefix]
        [HarmonyPriority(Priority.First)]
        private static void Prefix(Character __0)
        {
            Magma.RegisterOriginalLavaHit(__0);

            /*
             * bool Prefix가 아니므로 원본 Lava.HitPlayer는 계속 실행됩니다.
             *
             * PEAK 원본 처리:
             * Injury +0.25
             * Hot +0.25
             * sinceGrounded = 0
             */
        }
    }

    /// <summary>
    /// StaminaFull의 모든 상태 보호를 제거하지 않습니다.
    ///
    /// 최근 원본 Lava.HitPlayer에 맞은 로컬 플레이어에 한해서만
    /// CanApplyProtection 결과를 false로 바꿉니다.
    /// 그 결과 원본 Injury/Hot 추가와 해당 상태의 유지가 허용됩니다.
    /// </summary>
    [HarmonyPatch(
        typeof(global::StaminaFull),
        "CanApplyProtection",
        new Type[]
        {
            typeof(Character)
        })]
    internal static class MagmaStaminaFullProtectionPatch
    {
        [HarmonyPostfix]
        private static void Postfix(
            Character __0,
            ref bool __result)
        {
            if (!__result)
            {
                return;
            }

            if (Magma.ShouldBypassStaminaFull(__0))
            {
                __result = false;
            }
        }
    }
}
